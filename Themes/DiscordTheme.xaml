<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ================================================================
         BLACK WIDOW — OBSIDIAN DESIGN SYSTEM
         Single source of truth for the entire application.

         Principles:
         1. Calm authority — built for 2AM production incidents
         2. WCAG AA compliant — every text/background pair ≥ 4.5:1
         3. Neutral dark — no purple/blue tint on backgrounds
         4. Professional, not playful — Linear/Vercel, not Discord
         ================================================================ -->

    <!-- ============================================================
         COLOR PALETTE: OBSIDIAN
         Neutral charcoal backgrounds, blue accent for trust,
         semantic colors that signal without alarming.
         ============================================================ -->

    <!-- Backgrounds — pure neutral dark (no color tint) -->
    <SolidColorBrush x:Key="BgPrimary"   Color="#0B0E13"/>  <!-- Deepest canvas -->
    <SolidColorBrush x:Key="BgSecondary" Color="#141820"/>  <!-- Panel surfaces -->
    <SolidColorBrush x:Key="BgTertiary"  Color="#1C2128"/>  <!-- Elevated cards -->
    <SolidColorBrush x:Key="BgInput"     Color="#272D36"/>  <!-- Inputs, dropdowns -->
    <SolidColorBrush x:Key="BgHover"     Color="#1E242C"/>  <!-- Interactive hover -->

    <!-- Sidebar — near-black for clean separation -->
    <SolidColorBrush x:Key="SidebarBg"      Color="#070A0E"/>
    <SolidColorBrush x:Key="SidebarBgHover" Color="#141820"/>
    <SolidColorBrush x:Key="SidebarBorder"  Color="#1C2128"/>

    <!-- Text — warm white hierarchy, all AA compliant on BgPrimary -->
    <SolidColorBrush x:Key="TextPrimary"   Color="#E6EDF3"/>  <!-- 15:1 contrast -->
    <SolidColorBrush x:Key="TextSecondary" Color="#9BA4AE"/>  <!-- 6.2:1 contrast -->
    <SolidColorBrush x:Key="TextMuted"     Color="#7D8590"/>  <!-- 4.6:1 contrast — AA pass -->
    <SolidColorBrush x:Key="TextDisabled"  Color="#484F58"/>  <!-- Decorative only -->

    <!-- Borders — quiet structure -->
    <SolidColorBrush x:Key="BorderDefault" Color="#2D333B"/>
    <SolidColorBrush x:Key="BorderSubtle"  Color="#1C2128"/>
    <SolidColorBrush x:Key="BorderFocus"   Color="#4493F8"/>

    <!-- Accent — professional blue (trustworthy, clear focus) -->
    <SolidColorBrush x:Key="AccentPrimary" Color="#4493F8"/>
    <SolidColorBrush x:Key="AccentHover"   Color="#1F6FEB"/>
    <SolidColorBrush x:Key="AccentActive"  Color="#1158C7"/>
    <SolidColorBrush x:Key="AccentSubtle"  Color="#4493F815"/>

    <!-- Semantic — clear signals, never panic-inducing -->
    <SolidColorBrush x:Key="Success"       Color="#3FB950"/>
    <SolidColorBrush x:Key="SuccessSubtle" Color="#3FB95018"/>
    <SolidColorBrush x:Key="Warning"       Color="#D29922"/>
    <SolidColorBrush x:Key="WarningSubtle" Color="#D2992218"/>
    <SolidColorBrush x:Key="Danger"        Color="#F85149"/>
    <SolidColorBrush x:Key="DangerSubtle"  Color="#F8514918"/>
    <SolidColorBrush x:Key="Info"          Color="#79C0FF"/>
    <SolidColorBrush x:Key="InfoSubtle"    Color="#79C0FF18"/>

    <!-- Log Level Colors -->
    <SolidColorBrush x:Key="LevelDebug" Color="#7D8590"/>
    <SolidColorBrush x:Key="LevelInfo"  Color="#4493F8"/>
    <SolidColorBrush x:Key="LevelWarn"  Color="#D29922"/>
    <SolidColorBrush x:Key="LevelError" Color="#F85149"/>
    <SolidColorBrush x:Key="LevelFatal" Color="#DA3633"/>

    <!-- Operation Type Colors -->
    <SolidColorBrush x:Key="OperationTrigger"     Color="#E05D44"/>
    <SolidColorBrush x:Key="OperationFlow"         Color="#4493F8"/>
    <SolidColorBrush x:Key="OperationLWC"          Color="#3FB950"/>
    <SolidColorBrush x:Key="OperationAsync"        Color="#BC8EDA"/>
    <SolidColorBrush x:Key="OperationIntegration"  Color="#D29922"/>
    <SolidColorBrush x:Key="OperationValidation"   Color="#E3B341"/>


    <!-- ============================================================
         TYPOGRAPHY SCALE
         Consistent, readable sizes. 13px minimum for body text.
         ============================================================ -->

    <FontFamily x:Key="FontPrimary">Segoe UI, Arial</FontFamily>
    <FontFamily x:Key="FontMono">Cascadia Code, Consolas, Courier New</FontFamily>

    <!-- Named sizes (used by theme styles) -->
    <sys:Double x:Key="FontSizeXS">11</sys:Double>
    <sys:Double x:Key="FontSizeSM">13</sys:Double>
    <sys:Double x:Key="FontBaseline">14</sys:Double>
    <sys:Double x:Key="FontSizeMD">15</sys:Double>
    <sys:Double x:Key="FontSizeLG">18</sys:Double>
    <sys:Double x:Key="FontSizeXL">24</sys:Double>
    <sys:Double x:Key="FontSize2XL">32</sys:Double>

    <!-- Aliases for backward compatibility (App.xaml naming) -->
    <sys:Double x:Key="FontSmall">12</sys:Double>
    <sys:Double x:Key="FontLarge">16</sys:Double>
    <sys:Double x:Key="FontXLarge">20</sys:Double>

    <!-- Short aliases (InsightsPanel naming) -->
    <sys:Double x:Key="FontXS">11</sys:Double>
    <sys:Double x:Key="FontSM">13</sys:Double>
    <sys:Double x:Key="FontMD">15</sys:Double>
    <sys:Double x:Key="FontLG">18</sys:Double>

    <!-- Weights -->
    <FontWeight x:Key="WeightNormal">Normal</FontWeight>
    <FontWeight x:Key="WeightMedium">Medium</FontWeight>
    <FontWeight x:Key="WeightSemiBold">SemiBold</FontWeight>
    <FontWeight x:Key="WeightBold">Bold</FontWeight>


    <!-- ============================================================
         SPACING SCALE (4px base)
         ============================================================ -->

    <sys:Double x:Key="Space1">4</sys:Double>
    <sys:Double x:Key="Space2">8</sys:Double>
    <sys:Double x:Key="Space3">12</sys:Double>
    <sys:Double x:Key="Space4">16</sys:Double>
    <sys:Double x:Key="Space5">20</sys:Double>
    <sys:Double x:Key="Space6">24</sys:Double>
    <sys:Double x:Key="Space8">32</sys:Double>
    <sys:Double x:Key="Space10">40</sys:Double>
    <sys:Double x:Key="Space12">48</sys:Double>

    <Thickness x:Key="PadSM">8</Thickness>
    <Thickness x:Key="PadMD">16</Thickness>
    <Thickness x:Key="PadLG">24</Thickness>


    <!-- ============================================================
         CORNER RADIUS
         ============================================================ -->

    <CornerRadius x:Key="RadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">8</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">12</CornerRadius>
    <CornerRadius x:Key="RadiusXLarge">16</CornerRadius>
    <CornerRadius x:Key="RadiusPill">999</CornerRadius>

    <!-- Short aliases (InsightsPanel naming) -->
    <CornerRadius x:Key="RadiusSM">4</CornerRadius>
    <CornerRadius x:Key="RadiusLG">12</CornerRadius>


    <!-- ============================================================
         SHADOWS
         ============================================================ -->

    <DropShadowEffect x:Key="ShadowSmall"  BlurRadius="8"  Opacity="0.25" ShadowDepth="2" Color="#000000"/>
    <DropShadowEffect x:Key="ShadowMedium" BlurRadius="16" Opacity="0.35" ShadowDepth="4" Color="#000000"/>
    <DropShadowEffect x:Key="ShadowLarge"  BlurRadius="24" Opacity="0.45" ShadowDepth="8" Color="#000000"/>


    <!-- ============================================================
         ANIMATION
         ============================================================ -->

    <Duration x:Key="DurationInstant">0:0:0.05</Duration>
    <Duration x:Key="DurationFast">0:0:0.1</Duration>
    <Duration x:Key="DurationStandard">0:0:0.17</Duration>
    <Duration x:Key="DurationSlow">0:0:0.3</Duration>

    <QuadraticEase x:Key="EaseOut" EasingMode="EaseOut"/>
    <CubicEase x:Key="EaseInOut" EasingMode="EaseInOut"/>
    <ExponentialEase x:Key="EaseOutExpo" Exponent="5" EasingMode="EaseOut"/>


    <!-- ============================================================
         COMPONENT STYLES
         One definition per component. No duplicates in views.
         ============================================================ -->

    <!-- Cards -->

    <Style x:Key="ModernCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgSecondary}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <Style x:Key="ElevatedCard" TargetType="Border" BasedOn="{StaticResource ModernCard}">
        <Setter Property="Background" Value="{StaticResource BgTertiary}"/>
        <Setter Property="Effect" Value="{StaticResource ShadowSmall}"/>
    </Style>

    <!-- Alias used by MainWindow -->
    <Style x:Key="DiscordCard" TargetType="Border" BasedOn="{StaticResource ModernCard}">
        <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <Style x:Key="LogCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgSecondary}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
        <Setter Property="Padding" Value="12,10,14,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BgHover}"/>
            </Trigger>
        </Style.Triggers>
    </Style>


    <!-- Buttons -->

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentPrimary}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="FontSize" Value="{StaticResource FontBaseline}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusSmall}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentActive}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BgTertiary}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefault}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="FontSize" Value="{StaticResource FontBaseline}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusSmall}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="{StaticResource FontBaseline}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusSmall}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PillButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentSubtle}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSM}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusPill}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentPrimary}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusMedium}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SidebarBgHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Danger Button (destructive actions) -->
    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource DangerSubtle}"/>
        <Setter Property="Foreground" Value="{StaticResource Danger}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="FontSize" Value="{StaticResource FontBaseline}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusSmall}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Danger}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- Badges -->

    <Style x:Key="Badge" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgInput}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusPill}"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <Style x:Key="SuccessBadge" TargetType="Border" BasedOn="{StaticResource Badge}">
        <Setter Property="Background" Value="{StaticResource SuccessSubtle}"/>
    </Style>

    <Style x:Key="WarningBadge" TargetType="Border" BasedOn="{StaticResource Badge}">
        <Setter Property="Background" Value="{StaticResource WarningSubtle}"/>
    </Style>

    <Style x:Key="DangerBadge" TargetType="Border" BasedOn="{StaticResource Badge}">
        <Setter Property="Background" Value="{StaticResource DangerSubtle}"/>
    </Style>


    <!-- Inputs -->

    <Style x:Key="ModernTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BgInput}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefault}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="{StaticResource FontBaseline}"/>
        <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource BorderFocus}"/>
            </Trigger>
        </Style.Triggers>
    </Style>


    <!-- Skeleton Loader -->

    <Style x:Key="SkeletonLoader" TargetType="Rectangle">
        <Setter Property="Fill" Value="{StaticResource BgInput}"/>
        <Setter Property="RadiusX" Value="4"/>
        <Setter Property="RadiusY" Value="4"/>
        <Setter Property="Opacity" Value="0.5"/>
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="0.3" To="0.7" Duration="0:0:1"
                                         AutoReverse="True"
                                         EasingFunction="{StaticResource EaseInOut}"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
