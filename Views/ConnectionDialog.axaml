<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="SalesforceDebugAnalyzer.Views.ConnectionDialog"
        Title="Connect to Salesforce"
        Width="560" Height="440"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{StaticResource BgSecondary}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Connect to Salesforce" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}"/>
            <TextBlock Text="Choose how you want to authenticate" FontSize="14"
                       Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Margin="0,0,0,16">

            <!-- Manual Token Tab (simplified for cross-platform) -->
            <TabItem Header="Access Token">
                <ScrollViewer Margin="0,12,0,0">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Quick connect using a Salesforce access token."
                                   Foreground="{StaticResource TextMuted}" FontSize="13"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Instance URL" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                        <TextBox x:Name="InstanceUrlTextBox"
                                 Watermark="https://your-instance.salesforce.com"
                                 Background="{StaticResource BgInput}"
                                 Foreground="{StaticResource TextPrimary}"
                                 BorderBrush="{StaticResource BorderSubtle}"
                                 Margin="0,4,0,12"/>

                        <TextBlock Text="Access Token" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                        <TextBox x:Name="AccessTokenTextBox"
                                 Watermark="00D..."
                                 Background="{StaticResource BgInput}"
                                 Foreground="{StaticResource TextPrimary}"
                                 BorderBrush="{StaticResource BorderSubtle}"
                                 Margin="0,4,0,16"/>

                        <Expander Header="How to get an access token?">
                            <Border Background="{StaticResource BgPrimary}"
                                    CornerRadius="6" Padding="14" Margin="0,8,0,0">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Salesforce CLI:" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <Border Background="{StaticResource BgTertiary}"
                                            CornerRadius="4" Padding="8,6">
                                        <TextBlock Text="sf org display --target-org yourOrg"
                                                   FontFamily="Cascadia Code,Consolas,monospace"
                                                   FontSize="12" Foreground="{StaticResource AccentPrimary}"/>
                                    </Border>
                                    <TextBlock Text="Workbench:" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource TextPrimary}" Margin="0,6,0,0"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12"
                                               Foreground="{StaticResource TextMuted}">
                                        Login at workbench.developerforce.com, then check browser cookies for the 'sid' value.
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Expander>

                        <Button x:Name="ManualConnectButton" Content="Connect with Token"
                                Classes="primary" Height="36" Margin="0,16,0,0"
                                Click="ManualConnectButton_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- OAuth Tab -->
            <TabItem Header="OAuth (Browser)">
                <ScrollViewer Margin="0,12,0,0">
                    <StackPanel Spacing="4">
                        <TextBlock TextWrapping="Wrap" FontSize="13"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,12">
                            Opens your browser to log in via Salesforce's secure OAuth 2.0 flow.
                        </TextBlock>

                        <CheckBox x:Name="UseSandboxCheckBox"
                                  Content="Use Sandbox (test.salesforce.com)"
                                  IsChecked="{Binding IsSandbox}"
                                  Foreground="{StaticResource TextPrimary}"
                                  Margin="0,0,0,12"/>

                        <Expander Header="How does this work?">
                            <Border Background="{StaticResource BgPrimary}"
                                    CornerRadius="6" Padding="14" Margin="0,8,0,0">
                                <StackPanel Spacing="4">
                                    <TextBlock TextWrapping="Wrap" FontSize="12"
                                               Foreground="{StaticResource TextMuted}">
                                        1. Click "Login with Browser" below
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontSize="12"
                                               Foreground="{StaticResource TextMuted}">
                                        2. Your browser opens to Salesforce login
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontSize="12"
                                               Foreground="{StaticResource TextMuted}">
                                        3. Approve access for Black Widow
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontSize="12"
                                               Foreground="{StaticResource TextMuted}">
                                        4. You'll be redirected back — done!
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,6,0,0"
                                               Foreground="{StaticResource TextDisabled}">
                                        Your credentials are never stored by Black Widow.
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Expander>

                        <Button x:Name="OAuthLoginButton" Content="Login with Browser"
                                Classes="primary" Height="36" Margin="0,16,0,0"
                                Click="OAuthLoginButton_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Footer: Status + Cancel -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusTextBlock" Text="Ready to connect"
                       VerticalAlignment="Center" FontSize="12"
                       Foreground="{StaticResource TextMuted}"/>

            <Button Grid.Column="1" Content="Cancel" Classes="secondary"
                    Click="CancelButton_Click" Padding="20,6"/>
        </Grid>
    </Grid>
</Window>
