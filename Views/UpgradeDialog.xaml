<Window x:Class="SalesforceDebugAnalyzer.Views.UpgradeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Upgrade to Black Widow Pro"
        Height="650" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#1E1F22"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <!-- Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#5865F2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4752C4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2B2D31"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="BorderBrush" Value="#404249"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#35373C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#5865F2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}" 
                                   Foreground="{TemplateBinding Foreground}"
                                   TextDecorations="Underline"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#7289DA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,24">
            <TextBlock Text="🕷️ Upgrade to Black Widow Pro" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Unlock transaction grouping, real-time streaming, and unlimited exports"
                       FontSize="14"
                       Foreground="#B5BAC1"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Feature Comparison Table -->
        <Border Grid.Row="2" 
                Background="#2B2D31" 
                CornerRadius="8" 
                Padding="0"
                Margin="0,0,0,24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Header Row -->
                <Border Grid.Row="0" Grid.ColumnSpan="4" Background="#5865F2" CornerRadius="8,8,0,0" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Feature" FontSize="14" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Grid.Column="1" Text="Free" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Pro" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="Team" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Row 1: Single log analysis -->
                <Border Grid.Row="1" Grid.ColumnSpan="4" Background="#313338" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Single log analysis" FontSize="13" Foreground="#DBDEE1"/>
                        <TextBlock Grid.Column="1" Text="✅" FontSize="16" Foreground="#23A559" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="✅" FontSize="16" Foreground="#23A559" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="✅" FontSize="16" Foreground="#23A559" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Row 2: Transaction grouping -->
                <Border Grid.Row="2" Grid.ColumnSpan="4" Background="#2B2D31" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Transaction grouping" FontSize="13" Foreground="#DBDEE1"/>
                        <TextBlock Grid.Column="1" Text="❌" FontSize="16" Foreground="#F23F43" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="✅" FontSize="16" Foreground="#23A559" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="✅" FontSize="16" Foreground="#23A559" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Row 3: File size limit -->
                <Border Grid.Row="3" Grid.ColumnSpan="4" Background="#313338" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="File size limit" FontSize="13" Foreground="#DBDEE1"/>
                        <TextBlock Grid.Column="1" Text="30MB" FontSize="13" Foreground="#F0B232" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Unlimited" FontSize="13" Foreground="#23A559" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="Unlimited" FontSize="13" Foreground="#23A559" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Row 4: CLI integration -->
                <Border Grid.Row="4" Grid.ColumnSpan="4" Background="#2B2D31" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Real-time CLI streaming" FontSize="13" Foreground="#DBDEE1"/>
                        <TextBlock Grid.Column="1" Text="❌" FontSize="16" Foreground="#F23F43" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="✅" FontSize="16" Foreground="#23A559" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="✅" FontSize="16" Foreground="#23A559" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Row 5: Export reports -->
                <Border Grid.Row="5" Grid.ColumnSpan="4" Background="#313338" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Export reports (PDF, JSON)" FontSize="13" Foreground="#DBDEE1"/>
                        <TextBlock Grid.Column="1" Text="❌" FontSize="16" Foreground="#F23F43" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="✅" FontSize="16" Foreground="#23A559" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="✅" FontSize="16" Foreground="#23A559" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Row 6: Marketplace -->
                <Border Grid.Row="6" Grid.ColumnSpan="4" Background="#2B2D31" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Marketplace access" FontSize="13" Foreground="#DBDEE1"/>
                        <TextBlock Grid.Column="1" Text="View" FontSize="13" Foreground="#F0B232" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Submit" FontSize="13" Foreground="#23A559" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="Submit" FontSize="13" Foreground="#23A559" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Row 7: Price -->
                <Border Grid.Row="7" Grid.ColumnSpan="4" Background="#313338" CornerRadius="0,0,8,8" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Price" FontSize="13" FontWeight="Bold" Foreground="#DBDEE1"/>
                        <TextBlock Grid.Column="1" Text="$0" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="$29/mo" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="or $249/year" FontSize="11" Foreground="#23A559" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                            <TextBlock Text="$99/mo" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="5 users" FontSize="11" Foreground="#B5BAC1" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Trial Offer -->
        <Border Grid.Row="3" 
                Background="#5865F2" 
                CornerRadius="8" 
                Padding="20"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="💎 Try Pro Free for 14 Days" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="No credit card required. Cancel anytime." 
                           FontSize="13" 
                           Foreground="#E3E5E8"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="StartTrialButton" 
                    Content="Start Free Trial" 
                    Style="{StaticResource PrimaryButton}"
                    Width="200"
                    Click="StartTrial_Click"
                    Margin="0,0,16,0"/>
            <Button x:Name="BuyNowButton" 
                    Content="Buy Now  $29/mo" 
                    Style="{StaticResource SecondaryButton}"
                    Width="200"
                    Click="BuyNow_Click"
                    Margin="0,0,16,0"/>
            <Button x:Name="ActivateKeyButton"
                    Content="I Have a Key"
                    Style="{StaticResource SecondaryButton}"
                    Width="160"
                    Click="ActivateKey_Click"
                    Margin="0,0,16,0"/>
            <Button x:Name="CancelButton" 
                    Content="Maybe Later" 
                    Style="{StaticResource LinkButton}"
                    Click="Cancel_Click"
                    Padding="8"/>
        </StackPanel>
    </Grid>
</Window>
