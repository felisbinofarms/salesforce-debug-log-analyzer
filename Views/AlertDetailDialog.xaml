<Window x:Class="SalesforceDebugAnalyzer.Views.AlertDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Alert Details" 
        Height="650" 
        Width="700"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border Background="{StaticResource BgSecondary}" 
            BorderBrush="{StaticResource BorderDefault}" 
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" 
                    Background="{StaticResource BgTertiary}"
                    BorderBrush="{StaticResource BorderDefault}" 
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0"
                    Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Alert Details" 
                                   FontSize="18" 
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock x:Name="TimeStamp" 
                                   FontSize="12" 
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                    
                    <Button Grid.Column="1" 
                            Click="Close_Click"
                            Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                            Background="Transparent" 
                            BorderThickness="0" 
                            Width="32" 
                            Height="32">
                        <materialDesign:PackIcon Kind="Close"
                                                 Foreground="{StaticResource TextSecondary}" 
                                                 Width="16" 
                                                 Height="16"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto"
                          Padding="20">
                <StackPanel>
                    <!-- Severity Badge -->
                    <Border x:Name="SeverityBadge"
                            HorizontalAlignment="Left"
                            CornerRadius="12" 
                            Padding="12,6"
                            Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon x:Name="SeverityIcon"
                                                     Width="16" 
                                                     Height="16"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,6,0"/>
                            <TextBlock x:Name="SeverityText" 
                                       FontSize="12" 
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Title -->
                    <TextBlock x:Name="AlertTitle" 
                               FontSize="20" 
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <!-- Description -->
                    <TextBlock x:Name="AlertDescription" 
                               FontSize="13" 
                               Foreground="{StaticResource TextSecondary}"
                               TextWrapping="Wrap"
                               LineHeight="22"
                               Margin="0,0,0,20"/>

                    <!-- Metrics Section -->
                    <Border x:Name="MetricsPanel"
                            Background="{StaticResource BgTertiary}"
                            BorderBrush="{StaticResource BorderDefault}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Current Value -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CURRENT" 
                                           FontSize="10" 
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMuted}"/>
                                <TextBlock x:Name="CurrentValueText" 
                                           FontSize="24" 
                                           FontWeight="Bold"
                                           Foreground="{StaticResource Danger}"
                                           Margin="0,4,0,0"/>
                                <TextBlock x:Name="MetricNameText" 
                                           FontSize="11" 
                                           Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>

                            <!-- Baseline -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="BASELINE" 
                                           FontSize="10" 
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMuted}"/>
                                <TextBlock x:Name="BaselineValueText" 
                                           FontSize="24" 
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}"
                                           Margin="0,4,0,0"/>
                                <TextBlock Text="Average" 
                                           FontSize="11" 
                                           Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>

                            <!-- Change -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="CHANGE" 
                                           FontSize="10" 
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMuted}"/>
                                <TextBlock x:Name="ChangeText" 
                                           FontSize="24" 
                                           FontWeight="Bold"
                                           Margin="0,4,0,0"/>
                                <TextBlock Text="Increase" 
                                           FontSize="11" 
                                           Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Additional Details -->
                    <Border Background="{StaticResource BgTertiary}"
                            BorderBrush="{StaticResource BorderDefault}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Details" 
                                       FontSize="12" 
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"
                                       Margin="0,0,0,12"/>
                            
                            <!-- Entry Point -->
                            <Grid x:Name="EntryPointRow" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" 
                                           Text="Entry Point:" 
                                           FontSize="12"
                                           Foreground="{StaticResource TextMuted}"/>
                                <TextBlock x:Name="EntryPointText" 
                                           Grid.Column="1" 
                                           FontSize="12"
                                           Foreground="{StaticResource AccentPrimary}"
                                           TextWrapping="Wrap"/>
                            </Grid>

                            <!-- Alert Type -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" 
                                           Text="Alert Type:" 
                                           FontSize="12"
                                           Foreground="{StaticResource TextMuted}"/>
                                <TextBlock x:Name="AlertTypeText" 
                                           Grid.Column="1" 
                                           FontSize="12"
                                           Foreground="{StaticResource TextPrimary}"/>
                            </Grid>

                            <!-- Related Log -->
                            <Grid x:Name="RelatedLogRow" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" 
                                           Text="Related Log:" 
                                           FontSize="12"
                                           Foreground="{StaticResource TextMuted}"/>
                                <Button x:Name="ViewLogButton"
                                        Grid.Column="1"
                                        Content="View Debug Log"
                                        Click="ViewLog_Click"
                                        Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                                        Foreground="{StaticResource AccentPrimary}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        HorizontalAlignment="Left"
                                        Padding="0"
                                        FontSize="12"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Feedback Section -->
                    <Border Background="{StaticResource BgPrimary}"
                            BorderBrush="{StaticResource BorderDefault}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Is this alert accurate?" 
                                       FontSize="13" 
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"
                                       Margin="0,0,0,12"/>
                            
                            <TextBlock Text="Your feedback helps improve alert detection accuracy." 
                                       FontSize="11" 
                                       Foreground="{StaticResource TextMuted}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>
                            
                            <!-- Feedback Buttons -->
                            <StackPanel x:Name="FeedbackButtons" Orientation="Horizontal">
                                <Button x:Name="ThumbsUpButton"
                                        Click="ThumbsUp_Click"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0"
                                        Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ThumbUp" 
                                                                 Width="16" 
                                                                 Height="16"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,8,0"/>
                                        <TextBlock Text="Accurate" 
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <Button x:Name="ThumbsDownButton"
                                        Click="ThumbsDown_Click"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ThumbDown" 
                                                                 Width="16" 
                                                                 Height="16"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,8,0"/>
                                        <TextBlock Text="False Alarm" 
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- Feedback Submitted Message -->
                            <Border x:Name="FeedbackSubmitted"
                                    Visibility="Collapsed"
                                    Background="{StaticResource SuccessSubtle}"
                                    BorderBrush="{StaticResource Success}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12,8"
                                    Margin="0,12,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CheckCircle" 
                                                             Width="16" 
                                                             Height="16"
                                                             Foreground="{StaticResource Success}"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,8,0"/>
                                    <TextBlock x:Name="FeedbackMessage"
                                               Text="Thanks for your feedback!" 
                                               FontSize="12"
                                               Foreground="{StaticResource Success}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" 
                    Background="{StaticResource BgTertiary}"
                    BorderBrush="{StaticResource BorderDefault}" 
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12"
                    Padding="20,16">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Dismiss Alert" 
                            Click="Dismiss_Click"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0"/>
                    <Button Content="Close" 
                            Click="Close_Click"
                            Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
