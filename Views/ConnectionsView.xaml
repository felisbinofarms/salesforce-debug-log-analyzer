<UserControl x:Class="SalesforceDebugAnalyzer.Views.ConnectionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             AllowDrop="True"
             PreviewDrop="DropZone_Drop"
             PreviewDragOver="DropZone_DragOver"
             PreviewDragLeave="DropZone_DragLeave">

    <Grid AllowDrop="True" Background="{StaticResource BgPrimary}">
        <!-- Center everything vertically and horizontally -->
        <Grid VerticalAlignment="Center" HorizontalAlignment="Center"
              MaxWidth="520" Margin="40,0" AllowDrop="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Branding -->
                <RowDefinition Height="40"/>    <!-- Spacer -->
                <RowDefinition Height="Auto"/>  <!-- Action cards -->
                <RowDefinition Height="24"/>    <!-- Spacer -->
                <RowDefinition Height="Auto"/>  <!-- Recent connections -->
                <RowDefinition Height="20"/>    <!-- Spacer -->
                <RowDefinition Height="Auto"/>  <!-- Advanced / Manual -->
            </Grid.RowDefinitions>

            <!-- ===== BRANDING ===== -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                <!-- Spider icon -->
                <Border CornerRadius="16" Width="64" Height="64"
                        HorizontalAlignment="Center" Margin="0,0,0,20"
                        Background="{StaticResource BgSecondary}"
                        BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1">
                    <materialDesign:PackIcon Kind="Spider" Width="36" Height="36"
                                             Foreground="{StaticResource AccentPrimary}"
                                             VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <!-- Title -->
                <TextBlock Text="BLACK WIDOW" FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>
                <TextBlock Text="Debug Log Analyzer"
                           FontSize="14"
                           Foreground="{StaticResource TextMuted}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- ===== ACTION CARDS ===== -->
            <StackPanel Grid.Row="2">

                <!-- Open Log File (drop zone + click) -->
                <Border x:Name="DropZoneBorder"
                        BorderThickness="1" CornerRadius="10"
                        Padding="16,14" Margin="0,0,0,8"
                        Cursor="Hand" AllowDrop="True"
                        MouseLeftButtonUp="DropZone_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BgSecondary}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                                    <Setter Property="Background" Value="{StaticResource BgHover}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid IsHitTestVisible="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="8" Width="40" Height="40"
                                Background="{StaticResource AccentSubtle}" Margin="0,0,14,0">
                            <materialDesign:PackIcon Kind="FileDocumentOutline" Width="22" Height="22"
                                                     Foreground="{StaticResource AccentPrimary}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="DropZoneText"
                                       Text="Open Log File"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Drop a .log file here or click to browse"
                                       FontSize="12" Foreground="{StaticResource TextMuted}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="Ctrl+O"
                                   FontSize="11" Foreground="{StaticResource TextDisabled}"
                                   FontFamily="{StaticResource FontMono}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Scan Folder -->
                <Border BorderThickness="1" CornerRadius="10"
                        Padding="16,14" Margin="0,0,0,8"
                        Cursor="Hand"
                        MouseLeftButtonUp="LoadFolder_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BgSecondary}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                                    <Setter Property="Background" Value="{StaticResource BgHover}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid IsHitTestVisible="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="8" Width="40" Height="40"
                                Background="{StaticResource SuccessSubtle}" Margin="0,0,14,0">
                            <materialDesign:PackIcon Kind="FolderOpenOutline" Width="22" Height="22"
                                                     Foreground="{StaticResource Success}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Scan Folder"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Load and analyze all logs in a directory"
                                       FontSize="12" Foreground="{StaticResource TextMuted}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Connect to Production -->
                <Border BorderThickness="1" CornerRadius="10"
                        Padding="16,14" Margin="0,0,0,8"
                        Cursor="Hand"
                        MouseLeftButtonUp="ConnectProduction_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BgSecondary}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                                    <Setter Property="Background" Value="{StaticResource BgHover}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid IsHitTestVisible="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="8" Width="40" Height="40"
                                Background="{StaticResource InfoSubtle}" Margin="0,0,14,0">
                            <materialDesign:PackIcon Kind="CloudOutline" Width="22" Height="22"
                                                     Foreground="{StaticResource Info}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Connect to Production"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="OAuth 2.0 · Stream logs live · SSO supported"
                                       FontSize="12" Foreground="{StaticResource TextMuted}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <materialDesign:PackIcon Grid.Column="2" Kind="ChevronRight"
                                                 Width="18" Height="18"
                                                 Foreground="{StaticResource TextDisabled}"
                                                 VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Connect to Sandbox -->
                <Border BorderThickness="1" CornerRadius="10"
                        Padding="16,14"
                        Cursor="Hand"
                        MouseLeftButtonUp="ConnectSandbox_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BgSecondary}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                                    <Setter Property="Background" Value="{StaticResource BgHover}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid IsHitTestVisible="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="8" Width="40" Height="40"
                                Background="{StaticResource WarningSubtle}" Margin="0,0,14,0">
                            <materialDesign:PackIcon Kind="TestTube" Width="22" Height="22"
                                                     Foreground="{StaticResource Warning}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Connect to Sandbox"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Sandbox or Developer org · MFA supported"
                                       FontSize="12" Foreground="{StaticResource TextMuted}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <materialDesign:PackIcon Grid.Column="2" Kind="ChevronRight"
                                                 Width="18" Height="18"
                                                 Foreground="{StaticResource TextDisabled}"
                                                 VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ===== RECENT CONNECTIONS ===== -->
            <StackPanel Grid.Row="4">
                <Border x:Name="RecentConnectionsPanel"
                        Visibility="Collapsed"
                        Background="{StaticResource BgSecondary}"
                        CornerRadius="10"
                        BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="RECENT"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="4,0,0,10"/>

                        <ItemsControl x:Name="RecentConnectionsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="ReconnectButton_Click"
                                            Tag="{Binding}"
                                            Style="{StaticResource GhostButton}"
                                            HorizontalContentAlignment="Stretch"
                                            Margin="0,0,0,2"
                                            Height="Auto"
                                            Padding="12,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <materialDesign:PackIcon Grid.Column="0"
                                                                     Kind="{Binding Icon}"
                                                                     Width="16" Height="16"
                                                                     VerticalAlignment="Center"
                                                                     Foreground="{StaticResource TextMuted}"
                                                                     Margin="0,0,10,0"/>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding OrgName}"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding LastUsed}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextDisabled}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="NoRecentConnectionsText"
                           Visibility="Collapsed"
                           Text="" FontSize="1"/>
            </StackPanel>

            <!-- ===== ADVANCED: MANUAL TOKEN ===== -->
            <Expander Grid.Row="6"
                      Header="Advanced: Manual Token"
                      Foreground="{StaticResource TextMuted}"
                      FontSize="12"
                      IsExpanded="False"
                      HorizontalAlignment="Stretch">
                <Border Background="{StaticResource BgSecondary}"
                        CornerRadius="10"
                        Padding="20"
                        Margin="0,8,0,0"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Instance URL" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="ManualInstanceUrl"
                                 Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Access Token" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="ManualAccessToken"
                                 Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,16"/>

                        <Button Content="Connect"
                                Click="ManualConnect_Click"
                                Style="{StaticResource SecondaryButton}"
                                Height="36"
                                Padding="20,0"/>
                    </StackPanel>
                </Border>
            </Expander>
        </Grid>
    </Grid>
</UserControl>