<UserControl x:Class="SalesforceDebugAnalyzer.Views.ConnectionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             AllowDrop="True"
             PreviewDrop="DropZone_Drop"
             PreviewDragOver="DropZone_DragOver"
             PreviewDragLeave="DropZone_DragLeave">

    <Grid AllowDrop="True" Background="{StaticResource BgPrimary}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" AllowDrop="True">
            <Grid Margin="32,40,32,40" AllowDrop="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ===== HERO SECTION ===== -->
                <Border Grid.Row="0" Background="{StaticResource BgSecondary}"
                        CornerRadius="12" Padding="40,48"
                        HorizontalAlignment="Stretch" MaxWidth="720"
                        BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1">
                    <StackPanel>
                        <!-- Logo + Title -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Border CornerRadius="10" Width="48" Height="48" Margin="0,0,14,0"
                                    Background="{StaticResource BgTertiary}">
                                <materialDesign:PackIcon Kind="Spider" Width="28" Height="28"
                                                         Foreground="{StaticResource AccentPrimary}"
                                                         VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Black Widow" FontSize="32" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Tagline — professional, clear value proposition -->
                        <TextBlock Text="Salesforce Debug Log Analyzer"
                                   FontSize="16"
                                   Foreground="{StaticResource TextMuted}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="Understand what your code did, how long it took, and what to fix — in plain English."
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondary}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="480"
                                   Margin="0,0,0,36"
                                   LineHeight="22"/>

                        <!-- Primary Actions -->
                        <StackPanel HorizontalAlignment="Stretch" MaxWidth="380">
                            <!-- Connect to Production -->
                            <Button Content="Connect to Production"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="ConnectProduction_Click"
                                    HorizontalAlignment="Stretch"
                                    Height="44" FontSize="15"
                                    Margin="0,0,0,10"/>

                            <!-- Connect to Sandbox -->
                            <Button Content="Connect to Sandbox"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="ConnectSandbox_Click"
                                    HorizontalAlignment="Stretch"
                                    Height="44" FontSize="14"
                                    Margin="0,0,0,6"/>

                            <!-- Connection benefit -->
                            <TextBlock FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,24"
                                       Foreground="{StaticResource TextMuted}" TextAlignment="Center">
                                Connect to download logs, configure debug levels, and stream logs live.
                            </TextBlock>

                            <!-- Divider -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Height="1" Background="{StaticResource BorderDefault}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="OR LOAD FROM DISK"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="11" FontWeight="SemiBold" Margin="12,0"/>
                                <Border Grid.Column="2" Height="1" Background="{StaticResource BorderDefault}" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Drop Zone -->
                            <Border x:Name="DropZoneBorder"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="24,20"
                                    Margin="0,0,0,12"
                                    Cursor="Hand"
                                    AllowDrop="True"
                                    MouseLeftButtonUp="DropZone_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource BgTertiary}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderDefault}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                                                <Setter Property="Background" Value="{StaticResource BgHover}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center" AllowDrop="True">
                                    <materialDesign:PackIcon Kind="FileDocumentOutline"
                                                             Width="28" Height="28"
                                                             Foreground="{StaticResource TextMuted}"
                                                             HorizontalAlignment="Center"
                                                             Margin="0,0,0,8"
                                                             IsHitTestVisible="False"/>
                                    <TextBlock x:Name="DropZoneText"
                                               Text="Drop a .log file or folder here"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"
                                               HorizontalAlignment="Center"
                                               IsHitTestVisible="False"/>
                                    <TextBlock Text="or click to browse"
                                               FontSize="12"
                                               Foreground="{StaticResource TextMuted}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0"
                                               IsHitTestVisible="False"/>
                                </StackPanel>
                            </Border>

                            <!-- Load Folder -->
                            <Button x:Name="LoadFolderButton"
                                    Click="LoadFolder_Click"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="40"
                                    Margin="0,0,0,20"
                                    HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FolderOpen"
                                                             Width="18" Height="18"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,8,0"/>
                                    <TextBlock Text="Load Folder of Logs" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Manual Token (Advanced) -->
                            <Expander Header="Advanced: Manual Token"
                                      Foreground="{StaticResource TextMuted}"
                                      FontSize="13"
                                      HorizontalAlignment="Stretch">
                                <Border Background="{StaticResource BgTertiary}"
                                        CornerRadius="8"
                                        Padding="20"
                                        Margin="0,8,0,0"
                                        BorderBrush="{StaticResource BorderDefault}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="For developers using Salesforce CLI or Workbench"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontSize="12"
                                                   Margin="0,0,0,16"/>

                                        <TextBlock Text="Instance URL" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                                        <TextBox x:Name="ManualInstanceUrl"
                                                 Style="{StaticResource ModernTextBox}"
                                                 Margin="0,0,0,12"/>

                                        <TextBlock Text="Access Token" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                                        <TextBox x:Name="ManualAccessToken"
                                                 Style="{StaticResource ModernTextBox}"
                                                 Margin="0,0,0,16"/>

                                        <Button Content="Connect"
                                                Click="ManualConnect_Click"
                                                Style="{StaticResource SecondaryButton}"
                                                Height="38"
                                                Padding="20,0"/>
                                    </StackPanel>
                                </Border>
                            </Expander>
                        </StackPanel>

                        <!-- Security Notice -->
                        <Border Background="{StaticResource BgTertiary}"
                                CornerRadius="8" Padding="16" Margin="0,32,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ShieldLockOutline"
                                                         Width="20" Height="20"
                                                         Foreground="{StaticResource Success}"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="Secure OAuth 2.0 Login"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="No passwords stored. SSO and MFA supported. Uses official Salesforce login."
                                               FontSize="12"
                                               Foreground="{StaticResource TextMuted}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ===== FEATURE CARDS ===== -->
                <ItemsControl Grid.Row="2">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.Items>

                        <!-- Feature 1: Quick Setup -->
                        <Border Width="260" Margin="8" CornerRadius="8" Padding="24"
                                Background="{StaticResource BgSecondary}"
                                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1">
                            <StackPanel>
                                <Border CornerRadius="8" Width="40" Height="40"
                                        HorizontalAlignment="Left" Margin="0,0,0,16"
                                        Background="{StaticResource AccentSubtle}">
                                    <materialDesign:PackIcon Kind="FlashOutline" Width="22" Height="22"
                                                             Foreground="{StaticResource AccentPrimary}"
                                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="30-Second Setup"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="Connect your org, enable debug logging, and start analyzing. The setup wizard handles everything."
                                           FontSize="13" Foreground="{StaticResource TextSecondary}"
                                           TextWrapping="Wrap" LineHeight="20"/>
                            </StackPanel>
                        </Border>

                        <!-- Feature 2: Instant Analysis -->
                        <Border Width="260" Margin="8" CornerRadius="8" Padding="24"
                                Background="{StaticResource BgSecondary}"
                                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1">
                            <StackPanel>
                                <Border CornerRadius="8" Width="40" Height="40"
                                        HorizontalAlignment="Left" Margin="0,0,0,16"
                                        Background="{StaticResource SuccessSubtle}">
                                    <materialDesign:PackIcon Kind="MagnifyScan" Width="22" Height="22"
                                                             Foreground="{StaticResource Success}"
                                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Instant Analysis"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="Health score, performance breakdown, and governor limit usage — all calculated in seconds."
                                           FontSize="13" Foreground="{StaticResource TextSecondary}"
                                           TextWrapping="Wrap" LineHeight="20"/>
                            </StackPanel>
                        </Border>

                        <!-- Feature 3: Plain English -->
                        <Border Width="260" Margin="8" CornerRadius="8" Padding="24"
                                Background="{StaticResource BgSecondary}"
                                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1">
                            <StackPanel>
                                <Border CornerRadius="8" Width="40" Height="40"
                                        HorizontalAlignment="Left" Margin="0,0,0,16"
                                        Background="{StaticResource WarningSubtle}">
                                    <materialDesign:PackIcon Kind="TextBoxOutline" Width="22" Height="22"
                                                             Foreground="{StaticResource Warning}"
                                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Plain English"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="Every log explained in plain language. What happened, what went wrong, and exactly what to fix."
                                           FontSize="13" Foreground="{StaticResource TextSecondary}"
                                           TextWrapping="Wrap" LineHeight="20"/>
                            </StackPanel>
                        </Border>

                        <!-- Feature 4: Live Streaming -->
                        <Border Width="260" Margin="8" CornerRadius="8" Padding="24"
                                Background="{StaticResource BgSecondary}"
                                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1">
                            <StackPanel>
                                <Border CornerRadius="8" Width="40" Height="40"
                                        HorizontalAlignment="Left" Margin="0,0,0,16"
                                        Background="{StaticResource InfoSubtle}">
                                    <materialDesign:PackIcon Kind="AccessPoint" Width="22" Height="22"
                                                             Foreground="{StaticResource Info}"
                                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Live Streaming"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="Connect to your org and watch debug logs appear in real time as you work in Salesforce."
                                           FontSize="13" Foreground="{StaticResource TextSecondary}"
                                           TextWrapping="Wrap" LineHeight="20"/>
                            </StackPanel>
                        </Border>

                    </ItemsControl.Items>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <!-- Recent Connections (positioned top-right, shown when available) -->
        <Border x:Name="RecentConnectionsPanel"
                Visibility="Collapsed"
                Background="{StaticResource BgSecondary}"
                CornerRadius="10"
                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                MaxWidth="340"
                Padding="20"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="0,48,32,0">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <materialDesign:PackIcon Kind="History"
                                             Width="18" Height="18"
                                             Foreground="{StaticResource TextMuted}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0"/>
                    <TextBlock Text="Recent Connections"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>

                <ItemsControl x:Name="RecentConnectionsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Click="ReconnectButton_Click"
                                    Tag="{Binding}"
                                    Style="{StaticResource GhostButton}"
                                    HorizontalContentAlignment="Stretch"
                                    Margin="0,0,0,4"
                                    Height="Auto"
                                    Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <materialDesign:PackIcon Grid.Column="0"
                                                             Kind="{Binding Icon}"
                                                             Width="18" Height="18"
                                                             VerticalAlignment="Center"
                                                             Foreground="{StaticResource TextMuted}"
                                                             Margin="0,0,10,0"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding OrgName}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="{Binding LastUsed}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock x:Name="NoRecentConnectionsText"
                           Text="No recent connections yet"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,8"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
