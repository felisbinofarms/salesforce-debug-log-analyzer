<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="SalesforceDebugAnalyzer.Views.StreamingOptionsDialog"
        Title="Streaming Options"
        Width="600" Height="520"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource BgTertiary}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Padding="20,16"
                Background="{DynamicResource BgSecondary}"
                BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <mi:MaterialIcon Kind="AccessPointNetwork" Width="24" Height="24"
                                 Foreground="{DynamicResource AccentPrimary}"/>
                <TextBlock Text="Streaming Options"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="24,16">
            <StackPanel Spacing="20">

                <!-- User Filter -->
                <Border Background="{DynamicResource BgSecondary}" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="User Filter" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <CheckBox x:Name="FilterByUserCheck" Content="Only show logs from specific user"
                                  Foreground="{DynamicResource TextSecondary}"/>
                        <TextBox x:Name="UsernameTextBox"
                                 Watermark="username@example.com"
                                 IsVisible="{Binding #FilterByUserCheck.IsChecked}"
                                 Margin="24,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Operation Type Filter -->
                <Border Background="{DynamicResource BgSecondary}" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Operation Types" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Choose which log types to capture"
                                   FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                        <WrapPanel Margin="0,4,0,0">
                            <CheckBox x:Name="IncludeApexCheck" Content="Apex Execution" IsChecked="True"
                                      Foreground="{DynamicResource TextSecondary}" Margin="0,4,16,4"/>
                            <CheckBox x:Name="IncludeFlowsCheck" Content="Flows" IsChecked="True"
                                      Foreground="{DynamicResource TextSecondary}" Margin="0,4,16,4"/>
                            <CheckBox x:Name="IncludeValidationCheck" Content="Validation Rules" IsChecked="True"
                                      Foreground="{DynamicResource TextSecondary}" Margin="0,4,16,4"/>
                            <CheckBox x:Name="IncludeLightningCheck" Content="Lightning Components" IsChecked="True"
                                      Foreground="{DynamicResource TextSecondary}" Margin="0,4,16,4"/>
                            <CheckBox x:Name="IncludeApiCheck" Content="API Calls" IsChecked="True"
                                      Foreground="{DynamicResource TextSecondary}" Margin="0,4,16,4"/>
                            <CheckBox x:Name="IncludeBatchCheck" Content="Batch/Scheduled" IsChecked="True"
                                      Foreground="{DynamicResource TextSecondary}" Margin="0,4,16,4"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Performance Options -->
                <Border Background="{DynamicResource BgSecondary}" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Performance Options" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <CheckBox x:Name="OnlyErrorsCheck" Content="Only capture logs with errors"
                                  Foreground="{DynamicResource TextSecondary}"/>
                        <CheckBox x:Name="SkipSlowCheck" Content="Skip processing for very large logs (>10MB)"
                                  Foreground="{DynamicResource TextSecondary}"/>
                        <CheckBox x:Name="AutoSwitchCheck" Content="Auto-switch to new logs as they arrive"
                                  IsChecked="True"
                                  Foreground="{DynamicResource TextSecondary}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="24,12"
                Background="{DynamicResource BgSecondary}"
                BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="CancelButton_Click" Classes="secondary" Padding="16,10"/>
                <Button Content="Start Streaming" Click="StartButton_Click" Classes="primary" Padding="16,10"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
