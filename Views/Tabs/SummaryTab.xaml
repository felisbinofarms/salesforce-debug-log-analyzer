<UserControl x:Class="SalesforceDebugAnalyzer.Views.Tabs.SummaryTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:SalesforceDebugAnalyzer.Helpers"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="900">
    <UserControl.Resources>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
        <StackPanel MaxWidth="900">

            <!-- ===== TRUNCATED LOG WARNING ===== -->
            <Border CornerRadius="8" Margin="0,0,0,12" Padding="14,10"
                    Background="{StaticResource WarningSubtle}"
                    BorderBrush="{StaticResource Warning}" BorderThickness="0,0,0,2"
                    Visibility="{Binding IsLogTruncated, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#x26A0;&#xFE0F;" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Log Truncated — Data May Be Incomplete" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource Warning}"/>
                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0" TextWrapping="Wrap"
                                   Text="Salesforce cut this log short before it finished writing. Governor limit counters, timing totals, and issue counts may be understated. Raise your debug level retention or reduce log verbosity."/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== PROFILING PARSE WARNING ===== -->
            <Border CornerRadius="8" Margin="0,0,0,12" Padding="14,10"
                    Background="{StaticResource WarningSubtle}"
                    BorderBrush="{StaticResource Warning}" BorderThickness="0,0,0,2"
                    Visibility="{Binding HasProfilingWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#x2699;&#xFE0F;" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Profiling Data Unavailable" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource Warning}"/>
                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0" TextWrapping="Wrap"
                                   Text="This log contains a CUMULATIVE_PROFILING section but the format didn't match the expected pattern. Top queries, DML, and method timing data may be missing. The log format may have changed in a recent Salesforce release."/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== TRANSACTION GROUP AGGREGATE METRICS ===== -->
            <Border CornerRadius="12" Margin="0,0,0,16" Padding="20" Background="{StaticResource AccentSubtle}"
                    BorderBrush="{StaticResource AccentPrimary}" BorderThickness="0,0,0,3">
                <Border.Visibility>
                    <MultiBinding Converter="{StaticResource MultiBooleanToVisibilityConverter}">
                        <Binding Path="ShowGroupedView"/>
                        <Binding Path="SelectedLogGroup" Converter="{StaticResource NullToBooleanConverter}"/>
                    </MultiBinding>
                </Border.Visibility>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#x1F4E6;" FontSize="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Transaction Group Analysis" FontSize="16" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="{Binding GroupSummary}" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                    <Border Grid.Row="1" Background="{StaticResource BgSecondary}" CornerRadius="8" Padding="14,10" Margin="0,0,0,10">
                        <TextBlock Text="{Binding GroupPhaseBreakdown}" FontSize="11" FontFamily="Consolas"
                                   Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                    </Border>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource BgSecondary}" CornerRadius="6" Padding="10,6" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="Total SOQL Queries" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentPrimary}" Margin="0,2,0,0">
                                    <Run Text="{Binding SelectedLogGroup.TotalSoqlQueries}"/>
                                    <Run Text=" / 100" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="{StaticResource BgSecondary}" CornerRadius="6" Padding="10,6" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="Total DML Statements" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentPrimary}" Margin="0,2,0,0">
                                    <Run Text="{Binding SelectedLogGroup.TotalDmlStatements}"/>
                                    <Run Text=" / 150" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="{StaticResource BgSecondary}" CornerRadius="6" Padding="10,6">
                            <StackPanel>
                                <TextBlock Text="Total CPU Time" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentPrimary}" Margin="0,2,0,0">
                                    <Run Text="{Binding SelectedLogGroup.TotalCpuTime}"/>
                                    <Run Text="ms" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- ===== MIXED CONTEXT WARNING ===== -->
            <Border CornerRadius="12" Margin="0,0,0,16" Padding="20,16" Background="{StaticResource BgTertiary}"
                    BorderBrush="{StaticResource Warning}" BorderThickness="0,0,0,3"
                    Visibility="{Binding ShowMixedContextWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#x1F50D;" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Governance Insight: Mixed Execution Contexts" FontSize="16" FontWeight="Bold" 
                                       Foreground="{StaticResource Warning}"/>
                            <TextBlock Text="This can make debugging confusing. Here's what's happening..."
                                       FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                    <Border Grid.Row="1" Background="{StaticResource BgSecondary}" CornerRadius="8" Padding="14,10" Margin="0,0,0,12">
                        <TextBlock Text="{Binding MixedContextExplanation}" TextWrapping="Wrap" FontSize="12" 
                                   Foreground="White" LineHeight="18"/>
                    </Border>
                    <StackPanel Grid.Row="2" Margin="0,0,0,12">
                        <TextBlock Text="What's in this transaction group:" FontSize="11" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                        <ItemsControl ItemsSource="{Binding ContextBreakdown}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BgTertiary}" CornerRadius="6" Padding="10,6" Margin="0,0,0,4">
                                        <TextBlock Text="{Binding}" FontSize="11" Foreground="{StaticResource TextSecondary}" FontFamily="Consolas"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    <Border Grid.Row="3" Background="{StaticResource SuccessSubtle}" CornerRadius="8" Padding="14,10" BorderBrush="{StaticResource Success}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Success}" Margin="0,0,0,6">
                                <Run Text="&#x1F4A1;"/>
                                <Run Text="Best Practice:"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondary}" LineHeight="16">
                                <Run Text="Create dedicated users for automation:"/>
                                <LineBreak/>
                                <Run Text="  • IntegrationUser for API calls (e.g., IntegrationUser-SAP)"/>
                                <LineBreak/>
                                <Run Text="  • BatchUser for scheduled jobs (e.g., BatchUser-NightlyCleanup)"/>
                                <LineBreak/>
                                <LineBreak/>
                                <Run Text="This keeps your debug logs clean and makes troubleshooting 10x easier!" FontStyle="Italic"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ============================================================ -->
            <!-- ===== HEALTH SCORE BAR (horizontal, replaces arc)      ===== -->
            <!-- ============================================================ -->
            <Border CornerRadius="8" Margin="0,0,0,16" Padding="16,12"
                    Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderDefault}" BorderThickness="1"
                    Visibility="{Binding HasHealthData, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Score text + status -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontSize="28" FontWeight="Bold" VerticalAlignment="Center"
                                       Foreground="{Binding HealthScore, Converter={StaticResource HealthScoreToColorConverter}}">
                                <Run Text="{Binding HealthScore, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Text="/100" FontSize="14" Foreground="{StaticResource TextMuted}" VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}">
                                <Run Text="{Binding HealthStatusIcon}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding HealthStatus}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding HealthPlainStatement}" FontSize="11" Foreground="{StaticResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="{StaticResource DangerSubtle}" CornerRadius="4" Padding="8,4" Margin="0,0,6,0"
                                    Visibility="{Binding CriticalIssues.Count, Converter={StaticResource GreaterThanZeroToVisibilityConverter}}">
                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                    <Run Text="{Binding CriticalIssues.Count, Mode=OneWay}" Foreground="{StaticResource Danger}"/>
                                    <Run Text=" critical" Foreground="{StaticResource Danger}"/>
                                </TextBlock>
                            </Border>
                            <Border Background="{StaticResource WarningSubtle}" CornerRadius="4" Padding="8,4"
                                    Visibility="{Binding HighPriorityIssues.Count, Converter={StaticResource GreaterThanZeroToVisibilityConverter}}">
                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                    <Run Text="{Binding HighPriorityIssues.Count, Mode=OneWay}" Foreground="{StaticResource Warning}"/>
                                    <Run Text=" high" Foreground="{StaticResource Warning}"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Grid>
                    <!-- Horizontal progress bar -->
                    <Border Grid.Row="1" Background="{StaticResource BgTertiary}" CornerRadius="4" Height="10">
                        <Border CornerRadius="4" HorizontalAlignment="Left"
                                Width="{Binding HealthScore, Converter={StaticResource PercentToWidthConverter}}"
                                Background="{Binding HealthScore, Converter={StaticResource HealthScoreToColorConverter}}"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ============================================================ -->
            <!-- ===== KEY METRICS — 4 cards in a row                   ===== -->
            <!-- ============================================================ -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Duration -->
                <Border Grid.Column="0" CornerRadius="8" Padding="12,10" Margin="0,0,6,0"
                        Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource BorderDefault}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Duration" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" ToolTip="{Binding DurationConfidenceTooltip}">
                            <TextBlock Text="{Binding DurationPrefix}" FontSize="12" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"
                                       Visibility="{Binding DurationPrefix, Converter={StaticResource StringToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding HeroDuration}" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                        <TextBlock Text="{Binding HeroEntryPoint}" FontSize="10" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"
                                   Visibility="{Binding HeroEntryPoint, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </StackPanel>
                </Border>

                <!-- SOQL -->
                <Border Grid.Column="1" CornerRadius="8" Padding="12,10" Margin="3,0"
                        Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource BorderDefault}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Reads (SOQL)" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"
                                   ToolTip="SOQL = Salesforce Object Query Language. Database read operations."/>
                        <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,4">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource AccentPrimary}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SoqlPercent, Converter={StaticResource PercentToSeverityConverter}}" Value="Warning">
                                            <Setter Property="Foreground" Value="{StaticResource Warning}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SoqlPercent, Converter={StaticResource PercentToSeverityConverter}}" Value="Critical">
                                            <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="{Binding StatSoqlCount, Mode=OneWay}"/>
                            <Run Text="/" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                            <Run Text="{Binding StatSoqlLimit, Mode=OneWay}" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                        </TextBlock>
                        <!-- Mini progress bar -->
                        <Border Background="{StaticResource BgTertiary}" CornerRadius="2" Height="4">
                            <Border CornerRadius="2" HorizontalAlignment="Left"
                                    Width="{Binding SoqlPercent, Converter={StaticResource PercentToWidthConverter}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource AccentPrimary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SoqlPercent, Converter={StaticResource PercentToSeverityConverter}}" Value="Warning">
                                                <Setter Property="Background" Value="{StaticResource Warning}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SoqlPercent, Converter={StaticResource PercentToSeverityConverter}}" Value="Critical">
                                                <Setter Property="Background" Value="{StaticResource Danger}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- DML -->
                <Border Grid.Column="2" CornerRadius="8" Padding="12,10" Margin="3,0"
                        Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource BorderDefault}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Writes (DML)" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"
                                   ToolTip="DML = Data Manipulation Language. Database write operations (insert, update, delete)."/>
                        <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,4">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource Warning}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DmlPercent, Converter={StaticResource PercentToSeverityConverter}}" Value="Warning">
                                            <Setter Property="Foreground" Value="{StaticResource Warning}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DmlPercent, Converter={StaticResource PercentToSeverityConverter}}" Value="Critical">
                                            <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="{Binding StatDmlCount, Mode=OneWay}"/>
                            <Run Text="/" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                            <Run Text="{Binding StatDmlLimit, Mode=OneWay}" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                        </TextBlock>
                        <!-- Mini progress bar -->
                        <Border Background="{StaticResource BgTertiary}" CornerRadius="2" Height="4">
                            <Border CornerRadius="2" HorizontalAlignment="Left"
                                    Width="{Binding DmlPercent, Converter={StaticResource PercentToWidthConverter}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource Warning}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DmlPercent, Converter={StaticResource PercentToSeverityConverter}}" Value="Warning">
                                                <Setter Property="Background" Value="{StaticResource Warning}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding DmlPercent, Converter={StaticResource PercentToSeverityConverter}}" Value="Critical">
                                                <Setter Property="Background" Value="{StaticResource Danger}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- CPU Time -->
                <Border Grid.Column="3" CornerRadius="8" Padding="12,10" Margin="6,0,0,0"
                        Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource BorderDefault}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="CPU Time" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"
                                   ToolTip="How long your Apex code ran. Limit is 10,000ms (10 sec)."/>
                        <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,4">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CpuPercent, Converter={StaticResource PercentToSeverityConverter}}" Value="Warning">
                                            <Setter Property="Foreground" Value="{StaticResource Warning}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CpuPercent, Converter={StaticResource PercentToSeverityConverter}}" Value="Critical">
                                            <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="{Binding StatCpuTime, Mode=OneWay}"/>
                            <Run Text="ms" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                        </TextBlock>
                        <!-- Mini progress bar -->
                        <Border Background="{StaticResource BgTertiary}" CornerRadius="2" Height="4">
                            <Border CornerRadius="2" HorizontalAlignment="Left"
                                    Width="{Binding CpuPercent, Converter={StaticResource PercentToWidthConverter}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource Success}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CpuPercent, Converter={StaticResource PercentToSeverityConverter}}" Value="Warning">
                                                <Setter Property="Background" Value="{StaticResource Warning}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CpuPercent, Converter={StaticResource PercentToSeverityConverter}}" Value="Critical">
                                                <Setter Property="Background" Value="{StaticResource Danger}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ============================================================ -->
            <!-- ===== CRITICAL ISSUES (Sentry-style, promoted to top)  ===== -->
            <!-- ============================================================ -->
            <StackPanel Visibility="{Binding CriticalIssues.Count, Converter={StaticResource GreaterThanZeroToVisibilityConverter}}" Margin="0,0,0,16">
                <TextBlock Text="&#x1F6A8; Critical Issues" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding CriticalIssues}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BgSecondary}" CornerRadius="8" Padding="14" Margin="0,0,0,8"
                                    BorderBrush="{StaticResource Danger}" BorderThickness="0,0,0,2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- Title + Location -->
                                    <Grid Grid.Row="0" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap">
                                            <Run Text="{Binding SeverityIcon, Mode=OneWay}"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding Title, Mode=OneWay}"/>
                                        </TextBlock>
                                        <Button Grid.Column="1" Style="{StaticResource PillLinkButton}"
                                                Command="{Binding DataContext.OpenInEditorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Location}"
                                                ToolTip="Open in VSCode" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding Location}" FontSize="10" FontFamily="Consolas"/>
                                        </Button>
                                    </Grid>
                                    <!-- Problem -->
                                    <TextBlock Grid.Row="1" Text="{Binding Problem}" FontSize="12" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                    <!-- Fix -->
                                    <Border Grid.Row="2" Background="{StaticResource BgHover}" CornerRadius="4" Padding="10,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontSize="11" Foreground="{StaticResource Success}" FontWeight="SemiBold" Margin="0,0,0,4">
                                                    <Run Text="&#x1F4A1; Fix:"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Fix}" FontSize="12" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding CodeExample}" FontSize="10" Foreground="{StaticResource Info}" FontFamily="Consolas" Margin="0,6,0,0" TextWrapping="Wrap"
                                                           Visibility="{Binding CodeExample, Converter={StaticResource StringToVisibilityConverter}}"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" VerticalAlignment="Top" Margin="8,0,0,0"
                                                    Command="{Binding DataContext.CopyIssueFixCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Fix}"
                                                    ToolTip="Copy fix" Background="{StaticResource SuccessSubtle}" BorderThickness="0"
                                                    Padding="6,4" Cursor="Hand">
                                                <materialDesign:PackIcon Kind="ContentCopy" Width="14" Height="14" Foreground="{StaticResource Success}"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- ===== HIGH PRIORITY ISSUES (compact) ===== -->
            <StackPanel Visibility="{Binding HighPriorityIssues.Count, Converter={StaticResource GreaterThanZeroToVisibilityConverter}}" Margin="0,0,0,16">
                <TextBlock Text="&#x26A0;&#xFE0F; High Priority" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding HighPriorityIssues}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BgSecondary}" CornerRadius="8" Padding="14" Margin="0,0,0,8"
                                    BorderBrush="{StaticResource Warning}" BorderThickness="0,0,0,2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap">
                                            <Run Text="{Binding SeverityIcon, Mode=OneWay}"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding Title, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1" Text="{Binding Location}" FontSize="10" FontFamily="Consolas"
                                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Text="{Binding Problem}" FontSize="12" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                    <TextBlock Grid.Row="2" FontSize="12" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap">
                                        <Run Text="Fix:" FontWeight="SemiBold" Foreground="{StaticResource Success}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding Fix, Mode=OneWay}"/>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- ===== QUICK WINS (compact list) ===== -->
            <StackPanel Visibility="{Binding QuickWins.Count, Converter={StaticResource GreaterThanZeroToVisibilityConverter}}" Margin="0,0,0,16">
                <TextBlock Text="&#x2705; Quick Wins" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding QuickWins}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BgSecondary}" CornerRadius="6" Padding="12,8" Margin="0,0,0,6"
                                    BorderBrush="{StaticResource Success}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="12" FontWeight="SemiBold">
                                            <Run Text="{Binding SeverityIcon, Mode=OneWay}"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding Title, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,2,0,0">
                                            <Run Text="{Binding Problem, Mode=OneWay}"/>
                                            <Run Text=" → " Foreground="{StaticResource TextMuted}"/>
                                            <Run Text="{Binding Fix, Mode=OneWay}" Foreground="{StaticResource Success}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" FontSize="10" Foreground="{StaticResource Success}" VerticalAlignment="Center" Margin="8,0,0,0">
                                        <Run Text="&#x23F1;&#xFE0F; "/>
                                        <Run Text="{Binding EstimatedFixTimeMinutes, Mode=OneWay}"/>
                                        <Run Text=" min"/>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- ===== CLEAN BILL OF HEALTH ===== -->
            <Border Background="{StaticResource SuccessSubtle}" CornerRadius="12" Padding="20" Margin="0,0,0,16" BorderBrush="{StaticResource Success}" BorderThickness="1"
                    Visibility="{Binding IsCleanBillOfHealth, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="TrophyVariantOutline" Width="40" Height="40"
                                             Foreground="{StaticResource Success}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Clean Bill of Health!" FontSize="18" FontWeight="Bold" 
                               Foreground="{StaticResource Success}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="No critical or high-priority issues found. This transaction looks great!" 
                               FontSize="13" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock FontSize="12" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center">
                        <Run Text="Health Score: "/>
                        <Run Text="{Binding HealthScore}" Foreground="{StaticResource Success}" FontWeight="Bold"/>
                        <Run Text="/100"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ============================================================ -->
            <!-- ===== EXECUTION BREAKDOWN (stacked bar)                ===== -->
            <!-- ============================================================ -->
            <StackPanel Margin="0,0,0,16"
                        Visibility="{Binding HasTimelineData, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Execution Breakdown" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Grid.Column="1" FontSize="11" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center">
                        <Run Text="{Binding TimelineTotalDurationMs, StringFormat={}{0:N0}ms}"/>
                        <Run Text=" total"/>
                    </TextBlock>
                </Grid>
                <Border Background="{StaticResource BgSecondary}" CornerRadius="6" Padding="4" BorderBrush="{StaticResource BorderDefault}" BorderThickness="1">
                    <ItemsControl ItemsSource="{Binding TimelineSegments}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="2" Padding="8,6" CornerRadius="4"
                                        Width="{Binding Percent, Converter={StaticResource PercentToWidthConverter}}"
                                        ToolTip="{Binding Name}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource AccentPrimary}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="Trigger">
                                                    <Setter Property="Background" Value="{StaticResource OperationTrigger}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Flow">
                                                    <Setter Property="Background" Value="{StaticResource OperationFlow}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Validation">
                                                    <Setter Property="Background" Value="{StaticResource OperationValidation}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="DML">
                                                    <Setter Property="Background" Value="{StaticResource OperationIntegration}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Async">
                                                    <Setter Property="Background" Value="{StaticResource OperationAsync}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Type}" FontSize="10" FontWeight="SemiBold" Foreground="White" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding DurationMs, StringFormat={}{0:N0}ms}" FontSize="10" Foreground="#FFFFFFBB"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
                <TextBlock Text="{Binding TimelineSummary}" FontSize="11" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                <TextBlock Text="{Binding TimelineSlowestLabel}" FontSize="11" Foreground="{StaticResource Warning}" Margin="0,2,0,0"
                           Visibility="{Binding TimelineSlowestLabel, Converter={StaticResource StringToVisibilityConverter}}"/>
            </StackPanel>

            <!-- ============================================================ -->
            <!-- ===== GOVERNOR LIMITS (compact, only approaching/exceeded) = -->
            <!-- ============================================================ -->
            <Border Background="{StaticResource BgSecondary}" CornerRadius="6" Padding="16" Margin="0,0,0,16"
                    BorderBrush="{StaticResource BorderDefault}" BorderThickness="1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Resource Usage" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                        <Border CornerRadius="4" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center"
                                Background="{StaticResource InfoSubtle}"
                                Visibility="{Binding IsAsyncExecution, Converter={StaticResource BooleanToVisibilityConverter}}"
                                ToolTip="Async transactions get higher governor limits — e.g. 200 SOQL instead of 100.">
                            <TextBlock Text="&#x26A1; Async Limits" FontSize="10" FontWeight="Bold" Foreground="{StaticResource Info}"/>
                        </Border>
                    </StackPanel>
                    <!-- SOQL -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Reads" FontSize="11" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="{StaticResource BgTertiary}" CornerRadius="3" Height="8">
                            <Border CornerRadius="3" HorizontalAlignment="Left" 
                                    Width="{Binding SoqlPercent, Converter={StaticResource PercentToWidthConverter}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource AccentPrimary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SoqlPercent, Converter={StaticResource PercentToSeverityConverter}}" Value="Warning">
                                                <Setter Property="Background" Value="{StaticResource Warning}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SoqlPercent, Converter={StaticResource PercentToSeverityConverter}}" Value="Critical">
                                                <Setter Property="Background" Value="{StaticResource Danger}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Border>
                        <TextBlock Grid.Column="2" FontSize="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Run Text="{Binding StatSoqlCount, Mode=OneWay}"/><Run Text="/"/><Run Text="{Binding StatSoqlLimit, Mode=OneWay}"/>
                        </TextBlock>
                    </Grid>
                    <!-- DML -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Writes" FontSize="11" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="{StaticResource BgTertiary}" CornerRadius="3" Height="8">
                            <Border CornerRadius="3" HorizontalAlignment="Left"
                                    Width="{Binding DmlPercent, Converter={StaticResource PercentToWidthConverter}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource Warning}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DmlPercent, Converter={StaticResource PercentToSeverityConverter}}" Value="Critical">
                                                <Setter Property="Background" Value="{StaticResource Danger}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Border>
                        <TextBlock Grid.Column="2" FontSize="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Run Text="{Binding StatDmlCount, Mode=OneWay}"/><Run Text="/"/><Run Text="{Binding StatDmlLimit, Mode=OneWay}"/>
                        </TextBlock>
                    </Grid>
                    <!-- CPU -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="CPU" FontSize="11" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="{StaticResource BgTertiary}" CornerRadius="3" Height="8">
                            <Border CornerRadius="3" HorizontalAlignment="Left"
                                    Width="{Binding CpuPercent, Converter={StaticResource PercentToWidthConverter}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource Success}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CpuPercent, Converter={StaticResource PercentToSeverityConverter}}" Value="Warning">
                                                <Setter Property="Background" Value="{StaticResource Warning}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CpuPercent, Converter={StaticResource PercentToSeverityConverter}}" Value="Critical">
                                                <Setter Property="Background" Value="{StaticResource Danger}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Border>
                        <TextBlock Grid.Column="2" FontSize="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Run Text="{Binding StatCpuTime, Mode=OneWay}"/><Run Text="ms / "/><Run Text="{Binding StatCpuLimit, Mode=OneWay}"/><Run Text="ms"/>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== BULK SAFETY GRADE ===== -->
            <Border CornerRadius="8" Margin="0,0,0,16" Padding="14"
                    Visibility="{Binding BulkSafetyGrade, Converter={StaticResource StringToVisibilityConverter}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource SuccessSubtle}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource Success}"/>
                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding BulkSafetyGrade}" Value="C">
                                <Setter Property="Background" Value="{StaticResource WarningSubtle}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource Warning}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding BulkSafetyGrade}" Value="D">
                                <Setter Property="Background" Value="{StaticResource DangerSubtle}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource Danger}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding BulkSafetyGrade}" Value="F">
                                <Setter Property="Background" Value="{StaticResource DangerSubtle}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource Danger}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="6" Margin="0,0,12,0" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource Success}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BulkSafetyGrade}" Value="C">
                                        <Setter Property="Background" Value="{StaticResource Warning}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BulkSafetyGrade}" Value="D">
                                        <Setter Property="Background" Value="{StaticResource Danger}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BulkSafetyGrade}" Value="F">
                                        <Setter Property="Background" Value="{StaticResource Danger}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding BulkSafetyGrade}" FontSize="22" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock FontSize="13" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                    <Setter Property="Text" Value="Bulk Safe"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding BulkSafetyGrade}" Value="C">
                                            <Setter Property="Text" Value="Bulk Safety Concern"/>
                                            <Setter Property="Foreground" Value="{StaticResource Warning}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding BulkSafetyGrade}" Value="D">
                                            <Setter Property="Text" Value="Bulk Safety Risk"/>
                                            <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding BulkSafetyGrade}" Value="F">
                                            <Setter Property="Text" Value="Not Bulk Safe"/>
                                            <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding BulkSafetyReason}" FontSize="11"
                                   Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================================================ -->
            <!-- ===== RECOMMENDATIONS (collapsed by default)           ===== -->
            <!-- ============================================================ -->
            <Expander IsExpanded="False" Margin="0,0,0,16"
                      Visibility="{Binding Recommendations.Count, Converter={StaticResource GreaterThanZeroToVisibilityConverter}}">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Lightbulb" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Foreground="{StaticResource Success}"/>
                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center">
                            <Run Text="{Binding Recommendations.Count, Mode=OneWay}"/>
                            <Run Text=" Recommendations"/>
                        </TextBlock>
                    </StackPanel>
                </Expander.Header>
                <Border Background="{StaticResource BgSecondary}" CornerRadius="6" Padding="14" Margin="0,8,0,0">
                    <ItemsControl ItemsSource="{Binding Recommendations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="10,6" Margin="0,0,0,6"
                                        Background="{StaticResource BgTertiary}">
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </Expander>

            <!-- ===== ANALYSIS SUMMARY (collapsed) ===== -->
            <Expander IsExpanded="False" Margin="0,0,0,16"
                      Visibility="{Binding FullSummaryText, Converter={StaticResource StringToVisibilityConverter}}">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileDocumentOutline" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Foreground="{StaticResource TextSecondary}"/>
                        <TextBlock Text="Full Analysis" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                        <Button x:Name="CopySummaryButton" Click="CopySummary_Click"
                                Margin="12,0,0,0" Padding="8,3" FontSize="11"
                                Background="{StaticResource BgTertiary}" Foreground="{StaticResource TextSecondary}"
                                BorderBrush="{StaticResource BorderDefault}" BorderThickness="1" Cursor="Hand"
                                ToolTip="Copy summary to clipboard" Content="&#x1F4CB; Copy"/>
                    </StackPanel>
                </Expander.Header>
                <Border Background="{StaticResource BgSecondary}" CornerRadius="6" Padding="16" Margin="0,8,0,0">
                    <TextBlock Text="{Binding FullSummaryText}" TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondary}" LineHeight="22"/>
                </Border>
            </Expander>

            <!-- ===== RAW DETAILS (Issues + Recommendations, collapsed) ===== -->
            <Expander IsExpanded="False" Margin="0,0,0,16"
                      Visibility="{Binding Issues.Count, Converter={StaticResource GreaterThanZeroToVisibilityConverter}}">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Wrench" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Foreground="{StaticResource TextSecondary}"/>
                        <TextBlock Text="Raw Technical Details" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Expander.Header>
                <StackPanel Margin="0,8,0,0">
                    <Border Background="{StaticResource BgSecondary}" CornerRadius="6" Padding="14" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <materialDesign:PackIcon Kind="BugOutline" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"
                                                         Foreground="{StaticResource Danger}"/>
                                <TextBlock Text="Issues" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Danger}" VerticalAlignment="Center"/>
                                <Border Background="{StaticResource Danger}" CornerRadius="8" Padding="6,2" Margin="6,0,0,0">
                                    <TextBlock Text="{Binding Issues.Count}" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                </Border>
                                <Button Click="CopyIssues_Click"
                                        Background="Transparent" BorderThickness="0" 
                                        Padding="8,3" FontSize="11" Cursor="Hand" Margin="8,0,0,0"
                                        ToolTip="Copy to clipboard">
                                    <materialDesign:PackIcon Kind="ContentCopy" Width="14" Height="14" Foreground="{StaticResource TextSecondary}"/>
                                </Button>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Issues}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="10,6" Margin="0,0,0,4"
                                                Background="{StaticResource BgTertiary}">
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</UserControl>
