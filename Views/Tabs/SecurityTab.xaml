<UserControl x:Class="SalesforceDebugAnalyzer.Views.Tabs.SecurityTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:tabs="clr-namespace:SalesforceDebugAnalyzer.Views.Tabs"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="900">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Section Toggle Header -->
        <Border Grid.Row="0" Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderDefault}" BorderThickness="0,0,0,1"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Page Title -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="ShieldLock" Width="20" Height="20"
                                             Foreground="{StaticResource AccentPrimary}"
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Security &amp; Compliance" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                </StackPanel>
                <!-- Segmented Toggle -->
                <Border Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="{StaticResource BgTertiary}" CornerRadius="6" Padding="3">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="ShieldToggle" IsChecked="True" GroupName="SecuritySection"
                                     Cursor="Hand" Checked="SectionToggle_Checked">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="Bg" CornerRadius="4" Padding="12,6" Cursor="Hand">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ShieldSearch" Width="14" Height="14"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0"
                                                                     Foreground="{StaticResource TextMuted}"/>
                                            <TextBlock x:Name="Lbl" Text="Shield Monitoring" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BgHover}"/>
                                            <Setter TargetName="Lbl" Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                        <RadioButton x:Name="PiiToggle" GroupName="SecuritySection"
                                     Cursor="Hand" Checked="SectionToggle_Checked">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="Bg" CornerRadius="4" Padding="12,6" Cursor="Hand">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ShieldLockOutline" Width="14" Height="14"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0"
                                                                     Foreground="{StaticResource TextMuted}"/>
                                            <TextBlock x:Name="Lbl" Text="PII Compliance" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BgHover}"/>
                                            <Setter TargetName="Lbl" Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Content: Shield or PII (toggled) -->
        <tabs:ShieldTab Grid.Row="1" x:Name="ShieldContent" Visibility="Visible"/>
        <tabs:PiiTab Grid.Row="1" x:Name="PiiContent" Visibility="Collapsed"/>
    </Grid>
</UserControl>
