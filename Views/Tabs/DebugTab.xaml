<UserControl x:Class="SalesforceDebugAnalyzer.Views.Tabs.DebugTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="900">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
        <StackPanel MaxWidth="900">
            <!-- Header -->
            <Border Background="{StaticResource BgInput}" BorderBrush="{StaticResource AccentPrimary}" BorderThickness="0,0,0,3" CornerRadius="6" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <materialDesign:PackIcon Kind="Bug" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource AccentPrimary}"/>
                        <TextBlock Text="Parser Debug" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock FontSize="12" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"
                               Text="Audit trail showing exactly where each metric came from — governor limit snapshot vs event-parsed counts, duration source, profiling section status, and health score breakdown."/>
                </StackPanel>
            </Border>

            <!-- Audit text (monospace) -->
            <Border Background="{StaticResource BgInput}" CornerRadius="6" Padding="16" Margin="0,0,0,12">
                <TextBlock Text="{Binding ParserDebugInfo}"
                           FontFamily="Consolas, Courier New, monospace"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondary}"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Footer note -->
            <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,0,16" TextWrapping="Wrap"
                       Text="Debug mode is enabled via settings.json (IsDebugMode: true). This tab is not visible to regular users."/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
