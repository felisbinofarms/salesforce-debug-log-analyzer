<UserControl x:Class="SalesforceDebugAnalyzer.Views.Tabs.PiiTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="900">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SidebarBg}" BorderBrush="{StaticResource BorderDefault}" BorderThickness="0,0,0,1" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="PII Compliance Scanner" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="{Binding PiiScanStatus}" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding ScanForPiiCommand}"
                        Content="🔍 Scan for PII"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{StaticResource AccentPrimary}"
                        Foreground="White" Padding="16,8"
                        IsEnabled="{Binding IsPiiScanning, Converter={StaticResource InverseBooleanConverter}}"/>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>

                <!-- Scanning spinner -->
                <StackPanel Visibility="{Binding IsPiiScanning, Converter={StaticResource BooleanToVisibilityConverter}}"
                            HorizontalAlignment="Center" Margin="0,40,0,0">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4" Margin="0,0,0,12"/>
                    <TextBlock Text="Scanning log lines for personal data…" FontSize="13" Foreground="{StaticResource TextSecondary}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Results (shown when scan is done) -->
                <StackPanel Visibility="{Binding HasPiiScan, Converter={StaticResource BooleanToVisibilityConverter}}">

                    <!-- Risk level banner -->
                    <Border CornerRadius="8" Padding="16,14" Margin="0,0,0,16" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#1A57F287"/>
                                <Setter Property="BorderBrush" Value="#57F287"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPiiScan.RiskLevel}" Value="Medium">
                                        <Setter Property="Background" Value="#1AD29922"/>
                                        <Setter Property="BorderBrush" Value="#D29922"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentPiiScan.RiskLevel}" Value="High">
                                        <Setter Property="Background" Value="#1AF85149"/>
                                        <Setter Property="BorderBrush" Value="#F85149"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CurrentPiiScan.RiskIcon}" FontSize="22" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock FontSize="15" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#57F287"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentPiiScan.RiskLevel}" Value="Medium">
                                                    <Setter Property="Foreground" Value="#D29922"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding CurrentPiiScan.RiskLevel}" Value="High">
                                                    <Setter Property="Foreground" Value="#F85149"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="{Binding CurrentPiiScan.RiskLevel, Mode=OneWay}"/><Run Text=" Risk — "/><Run Text="{Binding CurrentPiiScan.TotalMatches, Mode=OneWay}"/><Run Text=" match(es)"/>
                                </TextBlock>
                                <TextBlock Text="{Binding CurrentPiiScan.SummaryText}" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- No findings message -->
                    <Border CornerRadius="8" Padding="20" Margin="0,0,0,16" Background="{StaticResource BgSecondary}"
                            BorderBrush="{StaticResource BorderDefault}" BorderThickness="1"
                            Visibility="{Binding CurrentPiiScan.HasPii, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="✅" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="No personal data detected" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                            <TextBlock Text="This log is safe to share with colleagues or support." FontSize="12"
                                       Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Findings list (grouped by PII type) -->
                    <ItemsControl ItemsSource="{Binding CurrentPiiScan.ByType}"
                                  Visibility="{Binding CurrentPiiScan.HasPii, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Padding="14" Margin="0,0,0,12" Background="{StaticResource BgSecondary}"
                                        BorderBrush="{StaticResource BorderDefault}" BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="{Binding Key}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                            <Border CornerRadius="10" Padding="6,1" Margin="8,0,0,0" Background="{StaticResource BgHover}">
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}">
                                                    <Run Text="{Binding Count, Mode=OneWay}"/><Run Text=" match(es)"/>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="LINE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}"/>
                                            <TextBlock Grid.Column="1" Text="MASKED VALUE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}"/>
                                            <TextBlock Grid.Column="2" Text="CONTEXT" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="4,5" CornerRadius="3">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="{StaticResource BgHover}"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="70"/>
                                                                <ColumnDefinition Width="160"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding LineNumber}" FontSize="11"
                                                                       Foreground="{StaticResource AccentPrimary}" FontFamily="Consolas"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding MaskedValue}" FontSize="11"
                                                                       Foreground="{Binding SeverityColor}" FontFamily="Consolas"
                                                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding MaskedValue}"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding Context}" FontSize="11"
                                                                       Foreground="{StaticResource TextMuted}" FontFamily="Consolas"
                                                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding Context}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Disclaimer -->
                    <Border CornerRadius="6" Padding="12,10" Margin="0,8,0,0" Background="{StaticResource BgSecondary}">
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextMuted}">
                            <Run FontWeight="SemiBold">Note:</Run>
                            <Run>This scanner detects common PII patterns (email, phone, SSN, credit cards, IP addresses). False positives are possible — review each match in context. Salesforce record IDs are not flagged. Redacted values shown above never contain the original data.</Run>
                        </TextBlock>
                    </Border>

                </StackPanel>

                <!-- Prompt to run scan (no scan yet) -->
                <Border CornerRadius="8" Padding="32" Margin="0,24,0,0"
                        Visibility="{Binding HasPiiScan, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                        Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource BorderDefault}" BorderThickness="1">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="ShieldLockOutline" Width="48" Height="48"
                                                 Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="Check for personal data before sharing" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                        <TextBlock TextWrapping="Wrap" MaxWidth="480" TextAlignment="Center" Margin="0,8,0,20"
                                   FontSize="12" Foreground="{StaticResource TextMuted}">
                            Run a scan to detect emails, phone numbers, SSNs, credit card numbers, and IP addresses that may have been logged during debug execution. Results are never stored or transmitted.
                        </TextBlock>
                        <Button Command="{Binding ScanForPiiCommand}"
                                Content="🔍 Scan This Log"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{StaticResource AccentPrimary}"
                                Foreground="White" Padding="20,10" HorizontalAlignment="Center"
                                IsEnabled="{Binding IsPiiScanning, Converter={StaticResource InverseBooleanConverter}}"/>
                        <TextBlock Margin="0,12,0,0" FontSize="11" Foreground="{StaticResource TextMuted}"
                                   HorizontalAlignment="Center"
                                   Visibility="{Binding SelectedLog.SourcePath, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Collapsed}">
                            <Run Text="Scanning: "/><Run Text="{Binding SelectedLog.SourcePath, Mode=OneWay, StringFormat='{}{0}', FallbackValue=''}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
