<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="using:System"
        xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:vm="clr-namespace:SalesforceDebugAnalyzer.ViewModels"
        xmlns:h="clr-namespace:SalesforceDebugAnalyzer.Helpers"
        xmlns:views="clr-namespace:SalesforceDebugAnalyzer.Views"
        x:Class="SalesforceDebugAnalyzer.Views.MainWindow"
        Title="Black Widow — Salesforce Debug Log Analyzer"
        Width="1600" Height="900"
        MinWidth="1200" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="48"
        Background="{StaticResource BgPrimary}"
        DragDrop.AllowDrop="True">

    <Window.Resources>
        <h:EqualsIntConverter x:Key="EqualsInt"/>
        <h:PositiveIntToBoolConverter x:Key="PositiveInt"/>
    </Window.Resources>

    <Grid Background="{StaticResource BgPrimary}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="56"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════ -->
        <!-- TITLE BAR (Row 0, 48px)                 -->
        <!-- ═══════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                Background="{StaticResource SidebarBg}"
                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1"
                IsHitTestVisible="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App Icon -->
                <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
                    <mi:MaterialIcon Kind="Spider" Width="22" Height="22"
                                     VerticalAlignment="Center" HorizontalAlignment="Center"
                                     Foreground="{StaticResource AccentPrimary}"/>
                </Border>

                <!-- App Title + Breadcrumb -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <TextBlock Text="Black Widow" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text=" › " FontSize="13" Foreground="{StaticResource TextMuted}"
                               IsVisible="{Binding SelectedLog, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    <TextBlock Text="{Binding SelectedLog.OperationType}" FontSize="13"
                               Foreground="{StaticResource TextSecondary}"
                               TextTrimming="CharacterEllipsis" MaxWidth="300"
                               IsVisible="{Binding SelectedLog, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                </StackPanel>

                <!-- Streaming Status Badge (center) -->
                <Border Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="{StaticResource Danger}" CornerRadius="10" Padding="10,4"
                        IsVisible="{Binding IsStreaming}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="White" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding StreamingStatus}"
                                   Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <!-- Window Controls (Right) -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <!-- Alert Bell -->
                    <Button Classes="windowControl" Command="{Binding ToggleAlertCenterCommand}"
                            ToolTip.Tip="Alerts">
                        <Grid>
                            <mi:MaterialIcon Kind="BellOutline"
                                             Foreground="{StaticResource TextSecondary}" Width="18" Height="18"/>
                            <Border Background="{StaticResource Danger}" CornerRadius="7"
                                    MinWidth="14" Height="14" Padding="3,0"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,-4,-4,0"
                                    IsVisible="{Binding UnreadAlertCount, Converter={x:Static ObjectConverters.IsNotNull},
                                               FallbackValue=False}">
                                <TextBlock Text="{Binding UnreadAlertCount}" FontSize="9" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Button>
                    <Button Classes="windowControl" Click="MinimizeButton_Click" ToolTip.Tip="Minimize">
                        <mi:MaterialIcon Kind="WindowMinimize" Foreground="{StaticResource TextSecondary}" Width="16" Height="16"/>
                    </Button>
                    <Button Classes="windowControl" Click="MaximizeButton_Click" ToolTip.Tip="Maximize">
                        <mi:MaterialIcon Kind="WindowMaximize" Foreground="{StaticResource TextSecondary}" Width="16" Height="16"/>
                    </Button>
                    <Button Classes="windowControl closeButton" Click="CloseButton_Click" ToolTip.Tip="Close">
                        <mi:MaterialIcon Kind="Close" Foreground="{StaticResource TextSecondary}" Width="16" Height="16"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════ -->
        <!-- LEFT SIDEBAR (56px icon rail)           -->
        <!-- ═══════════════════════════════════════ -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource SidebarBg}"
                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Nav Icons (Top) -->
                <StackPanel Grid.Row="0" Margin="0,12,0,0" HorizontalAlignment="Center" Spacing="6">
                    <!-- Home -->
                    <Button Classes="sidebar-active" ToolTip.Tip="Home">
                        <mi:MaterialIcon Kind="Home" Foreground="White" Width="24" Height="24"/>
                    </Button>

                    <!-- Upload File -->
                    <Button Classes="sidebar" Command="{Binding UploadLogCommand}" ToolTip.Tip="Upload log file (Ctrl+O)">
                        <mi:MaterialIcon Kind="Upload" Foreground="{StaticResource TextSecondary}" Width="24" Height="24"/>
                    </Button>

                    <!-- Load Folder -->
                    <Button Classes="sidebar" Command="{Binding LoadLogFolderCommand}" ToolTip.Tip="Load log folder (Ctrl+Shift+O)">
                        <mi:MaterialIcon Kind="FolderOpen" Foreground="{StaticResource TextSecondary}" Width="24" Height="24"/>
                    </Button>

                    <!-- Go Live -->
                    <Button Classes="sidebar" Command="{Binding ToggleStreamingCommand}" ToolTip.Tip="Go Live — Stream logs">
                        <Grid>
                            <mi:MaterialIcon Kind="AccessPoint" Foreground="{StaticResource TextSecondary}" Width="24" Height="24"/>
                            <Ellipse Width="8" Height="8" Fill="{StaticResource Success}"
                                     HorizontalAlignment="Right" VerticalAlignment="Top"
                                     IsVisible="{Binding IsStreaming}"/>
                        </Grid>
                    </Button>

                    <!-- Separator -->
                    <Border Height="1" Width="32" Background="{StaticResource BorderDefault}" Margin="0,6"/>

                    <!-- Manage Debug Logs -->
                    <Button Classes="sidebar" Command="{Binding ManageDebugLogsCommand}" ToolTip.Tip="Manage Debug Logs">
                        <mi:MaterialIcon Kind="TextBoxSearch" Foreground="{StaticResource TextSecondary}" Width="24" Height="24"/>
                    </Button>

                    <!-- Export -->
                    <Button Classes="sidebar" Command="{Binding ExportReportCommand}" ToolTip.Tip="Export Report (Ctrl+E)">
                        <mi:MaterialIcon Kind="Download" Foreground="{StaticResource TextSecondary}" Width="24" Height="24"/>
                    </Button>
                </StackPanel>

                <!-- Nav Icons (Bottom) -->
                <StackPanel Grid.Row="1" Margin="0,0,0,12" HorizontalAlignment="Center" Spacing="6">
                    <!-- Settings -->
                    <Button Classes="sidebar" Command="{Binding OpenSettingsCommand}" ToolTip.Tip="Settings (Ctrl+,)">
                        <mi:MaterialIcon Kind="Cog" Foreground="{StaticResource TextSecondary}" Width="24" Height="24"/>
                    </Button>

                    <!-- Disconnect -->
                    <Button Classes="sidebar" Command="{Binding DisconnectCommand}" ToolTip.Tip="Disconnect">
                        <mi:MaterialIcon Kind="Power" Foreground="{StaticResource Danger}" Width="24" Height="24"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════ -->
        <!-- MAIN CONTENT (Row 1, Column 1)          -->
        <!-- ═══════════════════════════════════════ -->
        <Grid Grid.Row="1" Grid.Column="1">

            <!-- ConnectionsView (shown when not connected) -->
            <Border x:Name="ConnectionsViewContainer"
                    IsVisible="{Binding !IsConnected}"
                    Background="{StaticResource BgPrimary}">
                <views:ConnectionsView x:Name="ConnectionsViewControl"/>
            </Border>

            <!-- Main Dashboard (shown when connected OR has logs) -->
            <Grid x:Name="MainContentGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Trial Banner -->
                <Border Grid.Row="0" Background="#F0B232" Padding="8,4"
                        IsVisible="{Binding ShowTrialBanner}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding TrialBannerText}" Foreground="#1C2128"
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Classes="ghost" Command="{Binding UpgradeCommand}"
                                Margin="8,0,0,0">
                            <TextBlock Text="Upgrade Now →" Foreground="#1C2128" FontWeight="Bold" FontSize="12"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Two-column layout: Log List + Analysis -->
                <Grid Grid.Row="1" Margin="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" MinWidth="300" MaxWidth="450"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ═══════════════════════════════ -->
                    <!-- LEFT: LOG LIST PANEL             -->
                    <!-- ═══════════════════════════════ -->
                    <Grid Grid.Column="0" Margin="12,12,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header: Title + Actions -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="Debug Logs" FontSize="18" FontWeight="Bold"/>
                                <Border Classes="badge" Background="{StaticResource AccentSubtle}"
                                        IsVisible="{Binding ShowGroupedView}">
                                    <TextBlock FontSize="11" Foreground="{StaticResource AccentPrimary}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="📦 {0} groups">
                                                <Binding Path="LogGroups.Count" FallbackValue="0"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                <Button Classes="ghost" Command="{Binding UploadLogCommand}" ToolTip.Tip="Upload log">
                                    <mi:MaterialIcon Kind="Plus" Foreground="{StaticResource TextSecondary}" Width="18" Height="18"/>
                                </Button>
                                <Button Classes="ghost" Command="{Binding LoadLogFolderCommand}" ToolTip.Tip="Load folder">
                                    <mi:MaterialIcon Kind="FolderOpen" Foreground="{StaticResource TextSecondary}" Width="18" Height="18"/>
                                </Button>
                                <Button Classes="ghost" Command="{Binding LoadRecentLogsCommand}" ToolTip.Tip="Download from Org">
                                    <mi:MaterialIcon Kind="CloudDownload" Foreground="{StaticResource TextSecondary}" Width="18" Height="18"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Search Box -->
                        <TextBox Grid.Row="1" x:Name="SearchBox" Classes="search"
                                 Margin="0,0,0,8"/>

                        <!-- Log List -->
                        <ListBox Grid.Row="2" x:Name="LogListBox"
                                 Classes="logList"
                                 ItemsSource="{Binding Logs}"
                                 SelectedItem="{Binding SelectedLog}"
                                 IsVisible="{Binding !ShowGroupedView}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BgSecondary}"
                                            CornerRadius="8" Margin="0,0,0,4" Padding="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Accent Bar -->
                                            <Border Grid.Column="0" CornerRadius="4,0,0,4"
                                                    Background="{StaticResource Success}"/>
                                            <!-- Content -->
                                            <StackPanel Grid.Column="1" Margin="12,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding OperationIcon}"
                                                               FontSize="14" Margin="0,0,6,0"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding OperationType}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <Border Grid.Column="2" Classes="badge"
                                                            Background="{StaticResource BgTertiary}" IsVisible="{Binding HasHealthScore}">
                                                        <TextBlock Text="{Binding HealthScore, StringFormat={}{0:N0}}"
                                                                   FontSize="10" FontWeight="Bold"
                                                                   Foreground="{StaticResource TextSecondary}"/>
                                                    </Border>
                                                </Grid>
                                                <TextBlock Text="{Binding EntryPoint}" FontSize="11"
                                                           Foreground="{StaticResource TextMuted}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,2,0,0"/>
                                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                                                    <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0:N0}ms">
                                                                <Binding Path="TotalDurationMs"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                    <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0:N0} lines">
                                                                <Binding Path="TotalLines"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Log Groups List -->
                        <ListBox Grid.Row="2"
                                 Classes="logList"
                                 ItemsSource="{Binding LogGroups}"
                                 SelectedItem="{Binding SelectedLogGroup}"
                                 IsVisible="{Binding ShowGroupedView}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BgSecondary}"
                                            CornerRadius="8" Margin="0,0,0,4" Padding="12,10">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="📦" FontSize="14"/>
                                                <TextBlock Text="{Binding UserName}" FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Text="transaction" FontSize="11"
                                                           Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} logs">
                                                            <Binding Path="LogCount"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0:N0}ms total">
                                                            <Binding Path="TotalDurationMs"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Empty State -->
                        <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    IsVisible="{Binding !HasLogs}" Spacing="12">
                            <mi:MaterialIcon Kind="FileDocumentOutline"
                                             Width="48" Height="48"
                                             Foreground="{StaticResource TextDisabled}"
                                             HorizontalAlignment="Center"/>
                            <TextBlock Text="No logs loaded" FontSize="14"
                                       Foreground="{StaticResource TextMuted}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Upload, drag-drop, or download from org"
                                       FontSize="12" Foreground="{StaticResource TextDisabled}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Sort/Filter Bar -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8"
                                    Margin="0,8,0,0"
                                    IsVisible="{Binding !IsStreaming}">
                            <Button Classes="ghost" Command="{Binding SortLogsCommand}" CommandParameter="Date"
                                    ToolTip.Tip="Sort by date">
                                <mi:MaterialIcon Kind="CalendarClock" Foreground="{StaticResource TextMuted}" Width="16" Height="16"/>
                            </Button>
                            <Button Classes="ghost" Command="{Binding SortLogsCommand}" CommandParameter="Duration"
                                    ToolTip.Tip="Sort by duration">
                                <mi:MaterialIcon Kind="TimerOutline" Foreground="{StaticResource TextMuted}" Width="16" Height="16"/>
                            </Button>
                            <Button Classes="ghost" Command="{Binding SortLogsCommand}" CommandParameter="Status"
                                    ToolTip.Tip="Sort by status">
                                <mi:MaterialIcon Kind="AlertCircleOutline" Foreground="{StaticResource TextMuted}" Width="16" Height="16"/>
                            </Button>
                        </StackPanel>

                        <!-- Live Stream Panel -->
                        <Border Grid.Row="3" Background="{StaticResource BgSecondary}"
                                CornerRadius="8" Padding="12"
                                IsVisible="{Binding IsStreaming}"
                                Margin="0,8,0,0">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource Danger}"/>
                                    <TextBlock Text="Live Stream" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Classes="primary" Command="{Binding StartRecordingCommand}"
                                            IsVisible="{Binding !IsRecording}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <mi:MaterialIcon Kind="Record" Foreground="White" Width="14" Height="14"/>
                                            <TextBlock Text="Record" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Classes="primary" Background="{StaticResource Danger}"
                                            Command="{Binding StopRecordingAsyncCommand}"
                                            IsVisible="{Binding IsRecording}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <mi:MaterialIcon Kind="Stop" Foreground="White" Width="14" Height="14"/>
                                            <TextBlock Text="{Binding RecordingElapsedTime}" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="1" Background="{StaticResource BorderSubtle}"
                                  ResizeDirection="Columns"/>

                    <!-- ═══════════════════════════════ -->
                    <!-- RIGHT: ANALYSIS DASHBOARD       -->
                    <!-- ═══════════════════════════════ -->
                    <Border Grid.Column="2" Background="{StaticResource BgSecondary}"
                            CornerRadius="10" Margin="12"
                            BorderBrush="{StaticResource BorderDefault}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Tab Bar -->
                            <Border Grid.Row="0" BorderBrush="{StaticResource BorderSubtle}"
                                    BorderThickness="0,0,0,1">
                                <Grid Margin="12,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Spacing="2">
                                        <Button Classes="tab" Command="{Binding SelectTabCommand}" Tag="0">
                                            <Button.CommandParameter><sys:Int32>0</sys:Int32></Button.CommandParameter>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <mi:MaterialIcon Kind="ChartBox" Width="16" Height="16"/>
                                                <TextBlock Text="Overview"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="tab" Command="{Binding SelectTabCommand}">
                                            <Button.CommandParameter><sys:Int32>1</sys:Int32></Button.CommandParameter>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <mi:MaterialIcon Kind="FileTree" Width="16" Height="16"/>
                                                <TextBlock Text="Tree"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="tab" Command="{Binding SelectTabCommand}">
                                            <Button.CommandParameter><sys:Int32>2</sys:Int32></Button.CommandParameter>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <mi:MaterialIcon Kind="TimelineClockOutline" Width="16" Height="16"/>
                                                <TextBlock Text="Timeline"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="tab" Command="{Binding SelectTabCommand}">
                                            <Button.CommandParameter><sys:Int32>3</sys:Int32></Button.CommandParameter>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <mi:MaterialIcon Kind="DatabaseSearch" Width="16" Height="16"/>
                                                <TextBlock Text="Queries"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="tab" Command="{Binding SelectTabCommand}">
                                            <Button.CommandParameter><sys:Int32>4</sys:Int32></Button.CommandParameter>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <mi:MaterialIcon Kind="Lightbulb" Width="16" Height="16"/>
                                                <TextBlock Text="Explain"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="tab" Command="{Binding SelectTabCommand}"
                                                IsVisible="{Binding IsConnected}">
                                            <Button.CommandParameter><sys:Int32>6</sys:Int32></Button.CommandParameter>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <mi:MaterialIcon Kind="ShieldLock" Width="16" Height="16"/>
                                                <TextBlock Text="Security"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                    <Button Grid.Column="1" Classes="ghost"
                                            Command="{Binding ExportReportCommand}" ToolTip.Tip="Export">
                                        <mi:MaterialIcon Kind="Download" Foreground="{StaticResource TextMuted}"
                                                         Width="16" Height="16"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Tab Content Area -->
                            <Grid Grid.Row="1">

                                <!-- Welcome/Empty State (when no log selected) -->
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            IsVisible="{Binding SelectedLog, Converter={x:Static ObjectConverters.IsNull}}"
                                            Spacing="16" MaxWidth="500">
                                    <mi:MaterialIcon Kind="Spider" Width="48" Height="48"
                                                     Foreground="{StaticResource AccentPrimary}"
                                                     HorizontalAlignment="Center"/>
                                    <TextBlock Text="Black Widow" FontSize="28" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="Salesforce Debug Log Analyzer" FontSize="14"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource TextSecondary}"/>
                                    <TextBlock Text="How do you want to start?" FontSize="13"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="0,12,0,0"/>

                                    <!-- Action Cards -->
                                    <StackPanel Orientation="Horizontal" Spacing="12"
                                                HorizontalAlignment="Center" Margin="0,8,0,0">
                                        <Button Classes="secondary" Command="{Binding UploadLogCommand}">
                                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                                <mi:MaterialIcon Kind="Upload" Width="24" Height="24"
                                                                 Foreground="{StaticResource AccentPrimary}"
                                                                 HorizontalAlignment="Center"/>
                                                <TextBlock Text="Upload File" FontSize="13" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="secondary" Command="{Binding LoadLogFolderCommand}">
                                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                                <mi:MaterialIcon Kind="FolderOpen" Width="24" Height="24"
                                                                 Foreground="{StaticResource Warning}"
                                                                 HorizontalAlignment="Center"/>
                                                <TextBlock Text="Load Folder" FontSize="13" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="secondary" Command="{Binding ToggleStreamingCommand}">
                                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                                <mi:MaterialIcon Kind="AccessPoint" Width="24" Height="24"
                                                                 Foreground="{StaticResource Success}"
                                                                 HorizontalAlignment="Center"/>
                                                <TextBlock Text="Go Live" FontSize="13" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <TextBlock Text="💡 Drag and drop a .log file anywhere"
                                               FontSize="12" Foreground="{StaticResource TextDisabled}"
                                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                                </StackPanel>

                                <!-- Tab Content (when log selected) -->
                                <Grid IsVisible="{Binding SelectedLog, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <!-- Summary Tab (Index 0) -->
                                    <ScrollViewer x:Name="SummaryTabContent"
                                                  IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualsInt}, ConverterParameter=0}">
                                        <StackPanel Margin="24" Spacing="16">

                                            <!-- Entry Point + Status Badge -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding HeroEntryPoint}" FontSize="16" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" CornerRadius="10" Padding="10,4"
                                                        Background="{StaticResource SuccessSubtle}">
                                                    <TextBlock Text="{Binding HeroStatus}" FontSize="11" FontWeight="Bold"
                                                               Foreground="{StaticResource Success}"/>
                                                </Border>
                                            </Grid>

                                            <!-- Hero Stats Row -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Duration Card -->
                                                <Border Grid.Column="0" Classes="elevated-card" Margin="0,0,6,0">
                                                    <StackPanel Spacing="2">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <mi:MaterialIcon Kind="TimerOutline" Width="14" Height="14"
                                                                             Foreground="{StaticResource TextMuted}"/>
                                                            <TextBlock Text="Duration" FontSize="11"
                                                                       Foreground="{StaticResource TextMuted}"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding HeroDuration}" FontSize="22" FontWeight="Bold"
                                                                   Foreground="{StaticResource TextPrimary}"/>
                                                        <TextBlock Text="{Binding SpeedRating}" FontSize="11"
                                                                   Foreground="{StaticResource TextMuted}"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- SOQL Card with Progress -->
                                                <Border Grid.Column="1" Classes="elevated-card" Margin="3,0,3,0">
                                                    <StackPanel Spacing="2">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <TextBlock Text="{Binding SoqlStatusIcon}" FontSize="11"/>
                                                            <TextBlock Text="SOQL" FontSize="11"
                                                                       Foreground="{StaticResource TextMuted}"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <TextBlock Text="{Binding StatSoqlCount}" FontSize="22" FontWeight="Bold"/>
                                                            <TextBlock Text="{Binding StatSoqlLimit, StringFormat=/ {0}}"
                                                                       FontSize="12" Foreground="{StaticResource TextMuted}"
                                                                       VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                                        </StackPanel>
                                                        <!-- Progress Bar -->
                                                        <Grid Height="4" Margin="0,2,0,0">
                                                            <Border CornerRadius="2" Background="{StaticResource BgTertiary}"/>
                                                            <Border CornerRadius="2" Background="{StaticResource AccentPrimary}"
                                                                    HorizontalAlignment="Left">
                                                                <Border.Width>
                                                                    <MultiBinding StringFormat="{}{0}%">
                                                                        <Binding Path="SoqlPercent"/>
                                                                    </MultiBinding>
                                                                </Border.Width>
                                                            </Border>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>

                                                <!-- DML Card with Progress -->
                                                <Border Grid.Column="2" Classes="elevated-card" Margin="3,0,3,0">
                                                    <StackPanel Spacing="2">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <TextBlock Text="{Binding DmlStatusIcon}" FontSize="11"/>
                                                            <TextBlock Text="DML" FontSize="11"
                                                                       Foreground="{StaticResource TextMuted}"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <TextBlock Text="{Binding StatDmlCount}" FontSize="22" FontWeight="Bold"/>
                                                            <TextBlock Text="{Binding DmlLimit, StringFormat=/ {0}}"
                                                                       FontSize="12" Foreground="{StaticResource TextMuted}"
                                                                       VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                                        </StackPanel>
                                                        <Grid Height="4" Margin="0,2,0,0">
                                                            <Border CornerRadius="2" Background="{StaticResource BgTertiary}"/>
                                                            <Border CornerRadius="2" Background="{StaticResource AccentPrimary}"
                                                                    HorizontalAlignment="Left">
                                                                <Border.Width>
                                                                    <MultiBinding StringFormat="{}{0}%">
                                                                        <Binding Path="DmlPercent"/>
                                                                    </MultiBinding>
                                                                </Border.Width>
                                                            </Border>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>

                                                <!-- CPU Card with Progress -->
                                                <Border Grid.Column="3" Classes="elevated-card" Margin="6,0,0,0">
                                                    <StackPanel Spacing="2">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <TextBlock Text="{Binding CpuStatusIcon}" FontSize="11"/>
                                                            <TextBlock Text="CPU" FontSize="11"
                                                                       Foreground="{StaticResource TextMuted}"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <TextBlock Text="{Binding StatCpuTime}" FontSize="22" FontWeight="Bold"/>
                                                            <TextBlock Text="{Binding StatCpuLimit, StringFormat=/ {0}ms}"
                                                                       FontSize="12" Foreground="{StaticResource TextMuted}"
                                                                       VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                                        </StackPanel>
                                                        <Grid Height="4" Margin="0,2,0,0">
                                                            <Border CornerRadius="2" Background="{StaticResource BgTertiary}"/>
                                                            <Border CornerRadius="2" Background="{StaticResource AccentPrimary}"
                                                                    HorizontalAlignment="Left">
                                                                <Border.Width>
                                                                    <MultiBinding StringFormat="{}{0}%">
                                                                        <Binding Path="CpuPercent"/>
                                                                    </MultiBinding>
                                                                </Border.Width>
                                                            </Border>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <!-- Health Score + What Happened (side by side) -->
                                            <Grid IsVisible="{Binding HasHealthData}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" MinWidth="160"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Health Score Card -->
                                                <Border Grid.Column="0" Classes="card" Margin="0,0,8,0">
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                                        <TextBlock Text="{Binding HealthGrade}" FontSize="48" FontWeight="Bold"
                                                                   Foreground="{StaticResource AccentPrimary}"
                                                                   HorizontalAlignment="Center"/>
                                                        <TextBlock Text="{Binding HealthScore, StringFormat={}{0:N0}/100}"
                                                                   FontSize="12" Foreground="{StaticResource TextMuted}"
                                                                   HorizontalAlignment="Center"/>
                                                        <TextBlock Text="{Binding HealthPlainStatement}" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   TextWrapping="Wrap" TextAlignment="Center"
                                                                   MaxWidth="140"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- What Happened -->
                                                <Border Grid.Column="1" Classes="card">
                                                    <StackPanel Spacing="8">
                                                        <TextBlock Text="What Happened" FontSize="15" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding PlainEnglishSummary}" FontSize="13"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   TextWrapping="Wrap"/>
                                                        <!-- Quick stats row -->
                                                        <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <mi:MaterialIcon Kind="Bug" Width="14" Height="14"
                                                                                 Foreground="{StaticResource Danger}"/>
                                                                <TextBlock Text="{Binding StatErrorCount, StringFormat={}{0} errors}"
                                                                           FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <mi:MaterialIcon Kind="AlertOutline" Width="14" Height="14"
                                                                                 Foreground="{StaticResource Warning}"/>
                                                                <TextBlock Text="{Binding StatWarningCount, StringFormat={}{0} warnings}"
                                                                           FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <mi:MaterialIcon Kind="Function" Width="14" Height="14"
                                                                                 Foreground="{StaticResource Info}"/>
                                                                <TextBlock Text="{Binding StatMethodCount, StringFormat={}{0} methods}"
                                                                           FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <!-- What Happened (solo when no health data) -->
                                            <Border Classes="card" IsVisible="{Binding !HasHealthData}">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="What Happened" FontSize="15" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding PlainEnglishSummary}" FontSize="13"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Timeline Strip (chronological phases) -->
                                            <Border Classes="card" IsVisible="{Binding HasTimelineData}">
                                                <StackPanel Spacing="8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Execution Timeline" FontSize="15" FontWeight="SemiBold"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding TimelineTotalDurationMs, StringFormat={}{0:N0}ms total}"
                                                                   FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                                    </Grid>
                                                    <!-- Horizontal phase bar -->
                                                    <ItemsControl ItemsSource="{Binding TimelineSegments}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal" Spacing="2"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Height="24" MinWidth="4" CornerRadius="4"
                                                                        Background="{StaticResource AccentPrimary}"
                                                                        ToolTip.Tip="{Binding Name}">
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <!-- Phase legend -->
                                                    <ItemsControl ItemsSource="{Binding TimelineSegments}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,2,0,0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="60"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="12"
                                                                               Margin="0,0,6,0"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12"
                                                                               Foreground="{StaticResource TextSecondary}"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock Grid.Column="2"
                                                                               Text="{Binding DurationMs, StringFormat={}{0:N0}ms}"
                                                                               FontSize="11" Foreground="{StaticResource TextMuted}"
                                                                               Margin="8,0"/>
                                                                    <TextBlock Grid.Column="3"
                                                                               Text="{Binding Percent, StringFormat={}{0:N0}%}"
                                                                               FontSize="11" Foreground="{StaticResource TextMuted}"
                                                                               HorizontalAlignment="Right"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <!-- Issues -->
                                            <Border Classes="card">
                                                <StackPanel Spacing="8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <mi:MaterialIcon Kind="AlertCircle" Width="18" Height="18"
                                                                         Foreground="{StaticResource Danger}"/>
                                                        <TextBlock Text="Issues" FontSize="15" FontWeight="SemiBold"/>
                                                        <Border Classes="badge-danger"
                                                                IsVisible="{Binding !!Issues.Count}">
                                                            <TextBlock Text="{Binding Issues.Count}" FontSize="11"
                                                                       Foreground="{StaticResource Danger}"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <ItemsControl ItemsSource="{Binding Issues}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{StaticResource DangerSubtle}"
                                                                        CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                                        <TextBlock Text="●" FontSize="8"
                                                                                   Foreground="{StaticResource Danger}"
                                                                                   VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding}" FontSize="13"
                                                                                   Foreground="{StaticResource TextSecondary}"
                                                                                   TextWrapping="Wrap"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <!-- Clean bill of health -->
                                                    <Border Background="{StaticResource SuccessSubtle}"
                                                            CornerRadius="6" Padding="12,8"
                                                            IsVisible="{Binding IsAllClear}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <mi:MaterialIcon Kind="CheckCircle" Width="16" Height="16"
                                                                             Foreground="{StaticResource Success}"/>
                                                            <TextBlock Text="No issues found — this log looks healthy!"
                                                                       FontSize="13" Foreground="{StaticResource Success}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Border>

                                            <!-- Recommendations -->
                                            <Border Classes="card">
                                                <StackPanel Spacing="8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                                            <mi:MaterialIcon Kind="LightbulbOnOutline" Width="18" Height="18"
                                                                             Foreground="{StaticResource Warning}"/>
                                                            <TextBlock Text="Recommendations" FontSize="15" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="2" Classes="ghost"
                                                                Command="{Binding CopyRecommendationsCommand}"
                                                                ToolTip.Tip="Copy recommendations">
                                                            <mi:MaterialIcon Kind="ContentCopy" Width="14" Height="14"
                                                                             Foreground="{StaticResource TextMuted}"/>
                                                        </Button>
                                                    </Grid>
                                                    <ItemsControl ItemsSource="{Binding Recommendations}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{StaticResource BgTertiary}"
                                                                        CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                                        <TextBlock Text="→" FontSize="13"
                                                                                   Foreground="{StaticResource AccentPrimary}"/>
                                                                        <TextBlock Text="{Binding}" FontSize="13"
                                                                                   Foreground="{StaticResource TextSecondary}"
                                                                                   TextWrapping="Wrap"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <!-- Duplicate Queries Warning -->
                                            <Border Classes="card" IsVisible="{Binding HasDuplicateQueries}">
                                                <StackPanel Spacing="8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <mi:MaterialIcon Kind="ContentDuplicate" Width="18" Height="18"
                                                                         Foreground="{StaticResource Warning}"/>
                                                        <TextBlock Text="Duplicate Queries (N+1 Pattern)" FontSize="15" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                    <TextBlock Text="These queries ran multiple times — a sign of queries inside loops."
                                                               FontSize="12" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                                                    <ItemsControl ItemsSource="{Binding DuplicateQueries}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{StaticResource WarningSubtle}"
                                                                        CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{Binding ExampleQuery}" FontSize="12"
                                                                                   FontFamily="Cascadia Code,Consolas,monospace"
                                                                                   Foreground="{StaticResource TextSecondary}"
                                                                                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                                                                   MaxLines="2"/>
                                                                        <Border Grid.Column="1" CornerRadius="8" Padding="8,2"
                                                                                Background="{StaticResource Warning}" Margin="8,0,0,0">
                                                                            <TextBlock Text="{Binding ExecutionCount, StringFormat=×{0}}"
                                                                                       FontSize="11" FontWeight="Bold" Foreground="#1C2128"/>
                                                                        </Border>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <!-- Tree Tab (Index 1) -->
                                    <ScrollViewer IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualsInt}, ConverterParameter=1}">
                                        <StackPanel Margin="24" Spacing="12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Execution Tree" FontSize="18" FontWeight="Bold"/>
                                                <TextBlock Grid.Column="1" FontSize="12"
                                                           Foreground="{StaticResource TextMuted}" VerticalAlignment="Center">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}Expand nodes to trace execution flow">
                                                            <Binding Path="HasExecutionTree"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Grid>
                                            <TreeView ItemsSource="{Binding ExecutionTreeNodes}"
                                                      Background="Transparent">
                                                <TreeView.ItemTemplate>
                                                    <TreeDataTemplate ItemsSource="{Binding Children}">
                                                        <Grid Margin="0,2,0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <!-- Type Icon + Name -->
                                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                                                                <TextBlock Text="{Binding TypeIcon}" FontSize="13"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Name}" FontSize="13"
                                                                           Foreground="{StaticResource TextPrimary}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           MaxWidth="500"/>
                                                            </StackPanel>
                                                            <!-- Duration Badge -->
                                                            <Border Grid.Column="2" CornerRadius="6" Padding="6,2"
                                                                    Background="{StaticResource BgTertiary}"
                                                                    Margin="8,0,0,0"
                                                                    VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding DurationDisplay}" FontSize="11"
                                                                           Foreground="{StaticResource TextMuted}"
                                                                           FontFamily="Cascadia Code,Consolas,monospace"/>
                                                            </Border>
                                                        </Grid>
                                                    </TreeDataTemplate>
                                                </TreeView.ItemTemplate>
                                            </TreeView>
                                            <!-- Empty state -->
                                            <StackPanel HorizontalAlignment="Center" Spacing="8"
                                                        IsVisible="{Binding !HasExecutionTree}" Margin="0,24,0,0">
                                                <mi:MaterialIcon Kind="FileTreeOutline" Width="36" Height="36"
                                                                 Foreground="{StaticResource TextDisabled}"
                                                                 HorizontalAlignment="Center"/>
                                                <TextBlock Text="No execution tree data available"
                                                           FontSize="13" Foreground="{StaticResource TextMuted}"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <!-- Timeline Tab (Index 2) -->
                                    <ScrollViewer IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualsInt}, ConverterParameter=2}">
                                        <StackPanel Margin="24" Spacing="16">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Execution Timeline" FontSize="18" FontWeight="Bold"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                                    <TextBlock Text="{Binding TimelineTotalDurationMs, StringFormat=Total: {0:N0}ms}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentPrimary}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="Each bar shows the relative time spent in each execution phase, in chronological order."
                                                       FontSize="12" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>

                                            <!-- Phase bars with proportional widths -->
                                            <ItemsControl ItemsSource="{Binding TimelineSegments}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,2" CornerRadius="6"
                                                                Background="{StaticResource BgTertiary}"
                                                                Padding="12,10">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="140"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="70"/>
                                                                    <ColumnDefinition Width="50"/>
                                                                </Grid.ColumnDefinitions>
                                                                <!-- Phase Icon -->
                                                                <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="14"
                                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                <!-- Phase Name -->
                                                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                                           FontSize="13" FontWeight="SemiBold"
                                                                           Foreground="{StaticResource TextPrimary}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           VerticalAlignment="Center"/>
                                                                <!-- Duration Bar (proportional) -->
                                                                <Grid Grid.Column="2" Height="12" VerticalAlignment="Center"
                                                                      Margin="8,0">
                                                                    <Border CornerRadius="3" Background="{StaticResource BgInput}"/>
                                                                    <Border CornerRadius="3" HorizontalAlignment="Left"
                                                                            Background="{StaticResource AccentPrimary}">
                                                                        <Border.Width>
                                                                            <MultiBinding StringFormat="{}{0}%">
                                                                                <Binding Path="Percent"/>
                                                                            </MultiBinding>
                                                                        </Border.Width>
                                                                    </Border>
                                                                </Grid>
                                                                <!-- Duration -->
                                                                <TextBlock Grid.Column="3"
                                                                           Text="{Binding DurationMs, StringFormat={}{0:N0}ms}"
                                                                           FontSize="12" FontWeight="SemiBold"
                                                                           Foreground="{StaticResource TextSecondary}"
                                                                           HorizontalAlignment="Right"
                                                                           VerticalAlignment="Center"/>
                                                                <!-- Percent -->
                                                                <TextBlock Grid.Column="4"
                                                                           Text="{Binding Percent, StringFormat={}{0:N0}%}"
                                                                           FontSize="11" Foreground="{StaticResource TextMuted}"
                                                                           HorizontalAlignment="Right"
                                                                           VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Slowest phase callout -->
                                            <Border Classes="card" IsVisible="{Binding TimelineSlowestLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                    Background="{StaticResource WarningSubtle}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <mi:MaterialIcon Kind="AlertOutline" Width="16" Height="16"
                                                                     Foreground="{StaticResource Warning}"/>
                                                    <TextBlock Text="Slowest phase:" FontSize="12"
                                                               Foreground="{StaticResource TextMuted}"/>
                                                    <TextBlock Text="{Binding TimelineSlowestLabel}" FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource Warning}"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Detailed Timeline Items -->
                                            <Border Classes="card" IsVisible="{Binding HasTimelineDetails}">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Detailed Execution Order" FontSize="15" FontWeight="SemiBold"/>
                                                    <ItemsControl ItemsSource="{Binding TimelineDetails}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,0,0,4">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="70"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="70"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0"
                                                                               Text="{Binding StartOffsetMs, StringFormat={}{0:N0}ms}"
                                                                               FontSize="11"
                                                                               FontFamily="Cascadia Code,Consolas,monospace"
                                                                               Foreground="{StaticResource TextDisabled}"/>
                                                                    <Border Grid.Column="1" Width="2" Margin="4,0,8,0"
                                                                            Background="{StaticResource BorderDefault}"/>
                                                                    <TextBlock Grid.Column="2"
                                                                               Text="{Binding Name}"
                                                                               FontSize="12"
                                                                               Foreground="{StaticResource TextSecondary}"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock Grid.Column="3"
                                                                               Text="{Binding DurationMs, StringFormat={}{0:N0}ms}"
                                                                               FontSize="11"
                                                                               Foreground="{StaticResource TextMuted}"
                                                                               HorizontalAlignment="Right"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <!-- Empty state -->
                                            <StackPanel HorizontalAlignment="Center" Spacing="8"
                                                        IsVisible="{Binding !HasTimelineData}" Margin="0,24,0,0">
                                                <mi:MaterialIcon Kind="TimelineClockOutline" Width="36" Height="36"
                                                                 Foreground="{StaticResource TextDisabled}"
                                                                 HorizontalAlignment="Center"/>
                                                <TextBlock Text="No timeline data available for this log"
                                                           FontSize="13" Foreground="{StaticResource TextMuted}"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <!-- Queries Tab (Index 3) -->
                                    <ScrollViewer IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualsInt}, ConverterParameter=3}">
                                        <StackPanel Margin="24" Spacing="16">
                                            <!-- Header with stats -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Database Operations" FontSize="18" FontWeight="Bold"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                                    <Border CornerRadius="8" Padding="8,3"
                                                            Background="{StaticResource InfoSubtle}">
                                                        <TextBlock Text="{Binding StatSoqlCount, StringFormat={}{0} SOQL}"
                                                                   FontSize="11" FontWeight="Bold"
                                                                   Foreground="{StaticResource Info}"/>
                                                    </Border>
                                                    <Border CornerRadius="8" Padding="8,3"
                                                            Background="{StaticResource AccentSubtle}">
                                                        <TextBlock Text="{Binding StatDmlCount, StringFormat={}{0} DML}"
                                                                   FontSize="11" FontWeight="Bold"
                                                                   Foreground="{StaticResource AccentPrimary}"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Managed package SOQL note -->
                                            <Border Background="{StaticResource InfoSubtle}" CornerRadius="6"
                                                    Padding="12,8" IsVisible="{Binding HasManagedPackageQueries}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <mi:MaterialIcon Kind="PackageVariantClosed" Width="14" Height="14"
                                                                     Foreground="{StaticResource Info}"/>
                                                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0} SOQL from your code + {1} from managed packages">
                                                                <Binding Path="RegularSoqlCount"/>
                                                                <Binding Path="ManagedPackageSoqlCount"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>

                                            <!-- Duplicate Queries (N+1 warning) -->
                                            <Border Classes="card" IsVisible="{Binding HasDuplicateQueries}"
                                                    Background="{StaticResource WarningSubtle}">
                                                <StackPanel Spacing="8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <mi:MaterialIcon Kind="AlertOutline" Width="16" Height="16"
                                                                         Foreground="{StaticResource Warning}"/>
                                                        <TextBlock Text="Duplicate Queries Detected (N+1 Pattern)"
                                                                   FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource Warning}"/>
                                                    </StackPanel>
                                                    <ItemsControl ItemsSource="{Binding DuplicateQueries}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,0,0,4">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Grid.Column="0" CornerRadius="8" Padding="6,2"
                                                                            Background="{StaticResource Warning}" Margin="0,0,8,0"
                                                                            VerticalAlignment="Top">
                                                                        <TextBlock Text="{Binding ExecutionCount, StringFormat=×{0}}"
                                                                                   FontSize="10" FontWeight="Bold" Foreground="#1C2128"/>
                                                                    </Border>
                                                                    <TextBlock Grid.Column="1" Text="{Binding ExampleQuery}" FontSize="12"
                                                                               FontFamily="Cascadia Code,Consolas,monospace"
                                                                               Foreground="{StaticResource TextSecondary}"
                                                                               TextWrapping="Wrap" MaxLines="2"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <!-- Top Queries section -->
                                            <Border Classes="card" IsVisible="{Binding HasTopQueries}">
                                                <StackPanel Spacing="8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <mi:MaterialIcon Kind="DatabaseClock" Width="16" Height="16"
                                                                         Foreground="{StaticResource Danger}"/>
                                                        <TextBlock Text="Slowest Queries" FontSize="14" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                    <ItemsControl ItemsSource="{Binding TopQueries}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{StaticResource BgTertiary}"
                                                                        CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                                                    <StackPanel Spacing="4">
                                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                                            <TextBlock Text="{Binding TimeDisplay}" FontSize="12"
                                                                                       FontWeight="Bold"
                                                                                       Foreground="{StaticResource Danger}"/>
                                                                            <TextBlock Text="{Binding CountBadge}" FontSize="11"
                                                                                       Foreground="{StaticResource TextMuted}"/>
                                                                        </StackPanel>
                                                                        <TextBlock Text="{Binding Query}" FontSize="12"
                                                                                   FontFamily="Cascadia Code,Consolas,monospace"
                                                                                   Foreground="{StaticResource TextSecondary}"
                                                                                   TextWrapping="Wrap" MaxLines="3"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <!-- All Operations -->
                                            <TextBlock Text="All Operations (chronological)" FontSize="14" FontWeight="SemiBold"
                                                       Margin="0,4,0,0"/>
                                            <ItemsControl ItemsSource="{Binding DatabaseOperations}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{StaticResource BgTertiary}"
                                                                CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                                            <StackPanel Spacing="4">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <Border CornerRadius="4" Padding="6,1"
                                                                            Background="{StaticResource InfoSubtle}">
                                                                        <TextBlock Text="{Binding OperationType}"
                                                                                   FontSize="10" FontWeight="Bold"
                                                                                   Foreground="{StaticResource Info}"/>
                                                                    </Border>
                                                                    <TextBlock Text="{Binding DurationMs, StringFormat={}{0:N0}ms}"
                                                                               FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                                                    <TextBlock Text="{Binding RowsAffected, StringFormat={}{0} rows}"
                                                                               FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                                                    <!-- Line number -->
                                                                    <TextBlock FontSize="10"
                                                                               Foreground="{StaticResource TextDisabled}">
                                                                        <TextBlock.Text>
                                                                            <MultiBinding StringFormat="L{0}">
                                                                                <Binding Path="LineNumber"/>
                                                                            </MultiBinding>
                                                                        </TextBlock.Text>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Query}"
                                                                           FontSize="12" FontFamily="Cascadia Code,Consolas,monospace"
                                                                           Foreground="{StaticResource TextSecondary}"
                                                                           TextWrapping="Wrap" MaxLines="4"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Callouts section -->
                                            <Border Classes="card" IsVisible="{Binding HasCallouts}">
                                                <StackPanel Spacing="8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <mi:MaterialIcon Kind="WebSync" Width="16" Height="16"
                                                                         Foreground="{StaticResource AccentPrimary}"/>
                                                        <TextBlock Text="External Callouts" FontSize="14" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                    <ItemsControl ItemsSource="{Binding Callouts}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{StaticResource BgTertiary}"
                                                                        CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                                                    <StackPanel Spacing="2">
                                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                                            <TextBlock Text="{Binding HttpMethod}" FontSize="11"
                                                                                       FontWeight="Bold"
                                                                                       Foreground="{StaticResource AccentPrimary}"/>
                                                                            <TextBlock Text="{Binding StatusCode}" FontSize="11"
                                                                                       Foreground="{StaticResource TextMuted}"/>
                                                                            <TextBlock Text="{Binding DurationMs, StringFormat={}{0:N0}ms}"
                                                                                       FontSize="11"
                                                                                       Foreground="{StaticResource TextMuted}"/>
                                                                        </StackPanel>
                                                                        <TextBlock Text="{Binding Endpoint}" FontSize="12"
                                                                                   FontFamily="Cascadia Code,Consolas,monospace"
                                                                                   Foreground="{StaticResource TextSecondary}"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <!-- Explain Tab (Index 4) -->
                                    <ScrollViewer IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualsInt}, ConverterParameter=4}">
                                        <StackPanel Margin="24" Spacing="16">
                                            <TextBlock Text="Plain English Explanation" FontSize="18" FontWeight="Bold"/>

                                            <!-- User Wait Time -->
                                            <Border Classes="card">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Margin="0,0,20,0"
                                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding UserWaitTimeSeconds}" FontSize="36" FontWeight="Bold"
                                                                   Foreground="{StaticResource AccentPrimary}"
                                                                   HorizontalAlignment="Center"/>
                                                        <TextBlock Text="seconds" FontSize="11"
                                                                   Foreground="{StaticResource TextMuted}"
                                                                   HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                        <TextBlock Text="User Wait Time" FontSize="14" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding UserWaitExplanation}" FontSize="13"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding ResourceUsageExplanation}" FontSize="12"
                                                                   Foreground="{StaticResource TextMuted}"
                                                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- Full Summary -->
                                            <Border Classes="card">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="What This Log Shows" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding FullSummaryText}" FontSize="13"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Problems in plain English -->
                                            <Border Classes="card" IsVisible="{Binding HasProblems}">
                                                <StackPanel Spacing="8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <mi:MaterialIcon Kind="AlertCircle" Width="16" Height="16"
                                                                         Foreground="{StaticResource Danger}"/>
                                                        <TextBlock Text="Problems Found" FontSize="14" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                    <ItemsControl ItemsSource="{Binding PlainEnglishProblems}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{StaticResource DangerSubtle}"
                                                                        CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                                                    <StackPanel Spacing="2">
                                                                        <TextBlock Text="{Binding Title}" FontSize="13"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource TextPrimary}"/>
                                                                        <TextBlock Text="{Binding Description}" FontSize="12"
                                                                                   Foreground="{StaticResource TextSecondary}"
                                                                                   TextWrapping="Wrap"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <!-- Recommendations in plain English -->
                                            <Border Classes="card" IsVisible="{Binding HasRecommendations}">
                                                <StackPanel Spacing="8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <mi:MaterialIcon Kind="LightbulbOnOutline" Width="16" Height="16"
                                                                         Foreground="{StaticResource Success}"/>
                                                        <TextBlock Text="What You Can Do" FontSize="14" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                    <ItemsControl ItemsSource="{Binding PlainEnglishRecommendations}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{StaticResource SuccessSubtle}"
                                                                        CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                                                    <StackPanel Spacing="2">
                                                                        <TextBlock Text="{Binding Title}" FontSize="13"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource TextPrimary}"/>
                                                                        <TextBlock Text="{Binding Description}" FontSize="12"
                                                                                   Foreground="{StaticResource TextSecondary}"
                                                                                   TextWrapping="Wrap"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <!-- Learning Items -->
                                            <Border Classes="card" IsVisible="{Binding HasLearningItems}">
                                                <StackPanel Spacing="8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <mi:MaterialIcon Kind="School" Width="16" Height="16"
                                                                         Foreground="{StaticResource Info}"/>
                                                        <TextBlock Text="Learn More" FontSize="14" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                    <ItemsControl ItemsSource="{Binding LearningItems}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{StaticResource InfoSubtle}"
                                                                        CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                                                    <StackPanel Spacing="2">
                                                                        <TextBlock Text="{Binding Concept}" FontSize="13"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource Info}"/>
                                                                        <TextBlock Text="{Binding Explanation}" FontSize="12"
                                                                                   Foreground="{StaticResource TextSecondary}"
                                                                                   TextWrapping="Wrap"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <!-- All-clear state -->
                                            <Border Background="{StaticResource SuccessSubtle}"
                                                    CornerRadius="8" Padding="20"
                                                    IsVisible="{Binding IsAllClear}"
                                                    HorizontalAlignment="Center">
                                                <StackPanel HorizontalAlignment="Center" Spacing="8">
                                                    <mi:MaterialIcon Kind="CheckCircle" Width="32" Height="32"
                                                                     Foreground="{StaticResource Success}"
                                                                     HorizontalAlignment="Center"/>
                                                    <TextBlock Text="This log looks healthy — no significant issues detected."
                                                               FontSize="14" Foreground="{StaticResource Success}"
                                                               HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <!-- Security Tab (Index 6) -->
                                    <ScrollViewer IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualsInt}, ConverterParameter=6}">
                                        <StackPanel Margin="24" Spacing="16">

                                            <!-- Header -->
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <mi:MaterialIcon Kind="ShieldLockOutline" Width="22" Height="22"
                                                                 Foreground="{StaticResource AccentPrimary}"/>
                                                <TextBlock Text="Security &amp; Compliance" FontSize="18" FontWeight="Bold"/>
                                            </StackPanel>

                                            <!-- ═══ PII COMPLIANCE SCANNER ═══ -->
                                            <Border Classes="card">
                                                <StackPanel Spacing="10">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <mi:MaterialIcon Kind="ShieldAlertOutline" Width="16" Height="16"
                                                                         Foreground="{StaticResource Warning}"/>
                                                        <TextBlock Text="PII Compliance Scanner" FontSize="14" FontWeight="SemiBold"/>
                                                    </StackPanel>

                                                    <TextBlock Text="Scan the selected log for personal identifiable information (emails, phone numbers, SSN, credit cards, IP addresses) before sharing."
                                                               FontSize="12" Foreground="{StaticResource TextSecondary}"
                                                               TextWrapping="Wrap"/>

                                                    <!-- Scan Button + Status -->
                                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                                        <Button Command="{Binding ScanForPiiCommand}"
                                                                Classes="accent" Padding="16,8" CornerRadius="6">
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <mi:MaterialIcon Kind="TextSearch" Width="14" Height="14"/>
                                                                <TextBlock Text="Scan for PII" FontSize="12" FontWeight="SemiBold"/>
                                                            </StackPanel>
                                                        </Button>
                                                        <TextBlock Text="{Binding PiiScanStatus}" FontSize="12"
                                                                   Foreground="{StaticResource TextMuted}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>

                                                    <!-- Scanning progress -->
                                                    <StackPanel IsVisible="{Binding IsPiiScanning}" Orientation="Horizontal" Spacing="8">
                                                        <mi:MaterialIcon Kind="Loading" Width="14" Height="14"
                                                                         Foreground="{StaticResource AccentPrimary}"/>
                                                        <TextBlock Text="Scanning…" FontSize="12"
                                                                   Foreground="{StaticResource AccentPrimary}"/>
                                                    </StackPanel>

                                                    <!-- PII Results -->
                                                    <StackPanel IsVisible="{Binding HasPiiScan}" Spacing="8">

                                                        <!-- Risk Level Badge -->
                                                        <Border CornerRadius="8" Padding="12,8"
                                                                Background="{StaticResource BgTertiary}">
                                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                                <TextBlock Text="{Binding CurrentPiiScan.RiskIcon}" FontSize="16"
                                                                           VerticalAlignment="Center"/>
                                                                <StackPanel>
                                                                    <TextBlock FontSize="13" FontWeight="SemiBold"
                                                                               Foreground="{StaticResource TextPrimary}">
                                                                        <TextBlock.Text>
                                                                            <MultiBinding StringFormat="Risk Level: {0}">
                                                                                <Binding Path="CurrentPiiScan.RiskLevel"/>
                                                                            </MultiBinding>
                                                                        </TextBlock.Text>
                                                                    </TextBlock>
                                                                    <TextBlock Text="{Binding CurrentPiiScan.SummaryText}" FontSize="11"
                                                                               Foreground="{StaticResource TextMuted}"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- PII Matches List -->
                                                        <ItemsControl ItemsSource="{Binding CurrentPiiScan.Matches}"
                                                                      IsVisible="{Binding CurrentPiiScan.HasPii}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="{StaticResource DangerSubtle}"
                                                                            CornerRadius="6" Padding="10,6" Margin="0,0,0,4">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Grid.Column="0" Text="{Binding PiiTypeIcon}" FontSize="14"
                                                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                            <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                                                                    Background="{StaticResource BgTertiary}" Margin="0,0,8,0"
                                                                                    VerticalAlignment="Center">
                                                                                <TextBlock Text="{Binding PiiType}" FontSize="10"
                                                                                           FontWeight="Bold"
                                                                                           Foreground="{StaticResource Warning}"/>
                                                                            </Border>
                                                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                                                <TextBlock Text="{Binding MaskedValue}" FontSize="12"
                                                                                           FontFamily="Cascadia Code,Consolas,monospace"
                                                                                           Foreground="{StaticResource TextPrimary}"/>
                                                                                <TextBlock Text="{Binding Context}" FontSize="10"
                                                                                           Foreground="{StaticResource TextMuted}"
                                                                                           TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                                            </StackPanel>
                                                                            <TextBlock Grid.Column="3" FontSize="10"
                                                                                       VerticalAlignment="Center"
                                                                                       Foreground="{StaticResource TextDisabled}">
                                                                                <TextBlock.Text>
                                                                                    <MultiBinding StringFormat="L{0}">
                                                                                        <Binding Path="LineNumber"/>
                                                                                    </MultiBinding>
                                                                                </TextBlock.Text>
                                                                            </TextBlock>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                        <!-- Clean state -->
                                                        <Border IsVisible="{Binding !CurrentPiiScan.HasPii}"
                                                                Background="{StaticResource SuccessSubtle}"
                                                                CornerRadius="8" Padding="16,12">
                                                            <StackPanel Orientation="Horizontal" Spacing="10"
                                                                        HorizontalAlignment="Center">
                                                                <mi:MaterialIcon Kind="ShieldCheckOutline" Width="18" Height="18"
                                                                                 Foreground="{StaticResource Success}"/>
                                                                <TextBlock Text="No personal data detected — safe to share"
                                                                           FontSize="13" Foreground="{StaticResource Success}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>

                                            <!-- ═══ SHIELD MONITORING DASHBOARD ═══ -->
                                            <Border Classes="card">
                                                <StackPanel Spacing="10">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <mi:MaterialIcon Kind="ShieldStarOutline" Width="16" Height="16"
                                                                         Foreground="{StaticResource AccentPrimary}"/>
                                                        <TextBlock Text="Shield Event Monitoring" FontSize="14" FontWeight="SemiBold"/>
                                                    </StackPanel>

                                                    <TextBlock Text="{Binding ShieldDashboardStatus}" FontSize="12"
                                                               Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>

                                                    <!-- Dashboard content (when data exists) -->
                                                    <StackPanel IsVisible="{Binding ShieldDashboard, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                                Spacing="12">

                                                        <!-- Quick Stats Row -->
                                                        <Grid ColumnDefinitions="*,*,*,*">
                                                            <Border Grid.Column="0" Classes="card" Margin="0,0,6,0">
                                                                <StackPanel HorizontalAlignment="Center">
                                                                    <TextBlock Text="{Binding ShieldDashboard.TotalEvents}"
                                                                               FontSize="20" FontWeight="Bold"
                                                                               Foreground="{StaticResource AccentPrimary}"
                                                                               HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="Total Events" FontSize="10"
                                                                               Foreground="{StaticResource TextMuted}"
                                                                               HorizontalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <Border Grid.Column="1" Classes="card" Margin="3,0,3,0">
                                                                <StackPanel HorizontalAlignment="Center">
                                                                    <TextBlock Text="{Binding ShieldDashboard.UniqueUsers}"
                                                                               FontSize="20" FontWeight="Bold"
                                                                               Foreground="{StaticResource Info}"
                                                                               HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="Unique Users" FontSize="10"
                                                                               Foreground="{StaticResource TextMuted}"
                                                                               HorizontalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <Border Grid.Column="2" Classes="card" Margin="3,0,3,0">
                                                                <StackPanel HorizontalAlignment="Center">
                                                                    <TextBlock Text="{Binding ShieldDashboard.ExceptionTotal}"
                                                                               FontSize="20" FontWeight="Bold"
                                                                               Foreground="{StaticResource Danger}"
                                                                               HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="Exceptions" FontSize="10"
                                                                               Foreground="{StaticResource TextMuted}"
                                                                               HorizontalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <Border Grid.Column="3" Classes="card" Margin="6,0,0,0">
                                                                <StackPanel HorizontalAlignment="Center">
                                                                    <TextBlock Text="{Binding ShieldDashboard.FailedLoginTotal}"
                                                                               FontSize="20" FontWeight="Bold"
                                                                               Foreground="{StaticResource Warning}"
                                                                               HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="Failed Logins" FontSize="10"
                                                                               Foreground="{StaticResource TextMuted}"
                                                                               HorizontalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </Grid>

                                                        <!-- Insights (actionable alerts) -->
                                                        <StackPanel IsVisible="{Binding ShieldDashboard.HasInsights}" Spacing="6">
                                                            <TextBlock Text="Actionable Insights" FontSize="13" FontWeight="SemiBold"
                                                                       Margin="0,4,0,0"/>
                                                            <ItemsControl ItemsSource="{Binding ShieldDashboard.Insights}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border CornerRadius="6" Padding="12,8" Margin="0,0,0,4"
                                                                                Background="{StaticResource BgTertiary}"
                                                                                BorderBrush="{StaticResource BorderSubtle}"
                                                                                BorderThickness="1">
                                                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                                                <!-- Severity indicator -->
                                                                                <Border Grid.Column="0" Width="4" CornerRadius="2"
                                                                                        Margin="0,0,10,0" VerticalAlignment="Stretch">
                                                                                    <Border.Background>
                                                                                        <SolidColorBrush Color="{Binding SeverityColor}"/>
                                                                                    </Border.Background>
                                                                                </Border>
                                                                                <!-- Content -->
                                                                                <StackPanel Grid.Column="1" Spacing="2">
                                                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                                                        <Border CornerRadius="3" Padding="4,1"
                                                                                                Background="{StaticResource BgHover}">
                                                                                            <TextBlock Text="{Binding SeverityLabel}"
                                                                                                       FontSize="9" FontWeight="Bold"
                                                                                                       Foreground="{StaticResource TextMuted}"/>
                                                                                        </Border>
                                                                                        <TextBlock Text="{Binding Title}" FontSize="13"
                                                                                                   FontWeight="SemiBold"
                                                                                                   Foreground="{StaticResource TextPrimary}"/>
                                                                                    </StackPanel>
                                                                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                                                                               Foreground="{StaticResource TextSecondary}"
                                                                                               TextWrapping="Wrap"/>
                                                                                    <TextBlock Text="{Binding Recommendation}"
                                                                                               IsVisible="{Binding HasRecommendation}"
                                                                                               FontSize="11" FontStyle="Italic"
                                                                                               Foreground="{StaticResource Success}"
                                                                                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                                                </StackPanel>
                                                                                <!-- Count badge -->
                                                                                <Border Grid.Column="2" CornerRadius="10" Padding="8,2"
                                                                                        Background="{StaticResource BgHover}"
                                                                                        VerticalAlignment="Top" Margin="8,0,0,0">
                                                                                    <TextBlock Text="{Binding CountDisplay}" FontSize="11"
                                                                                               FontWeight="Bold"
                                                                                               Foreground="{StaticResource TextMuted}"/>
                                                                                </Border>
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>

                                                        <!-- Failed Logins Detail -->
                                                        <StackPanel IsVisible="{Binding ShieldDashboard.FailedLoginTotal}" Spacing="6">
                                                            <TextBlock Text="Failed Login Analysis" FontSize="13" FontWeight="SemiBold"
                                                                       Margin="0,4,0,0"/>
                                                            <ItemsControl ItemsSource="{Binding ShieldDashboard.LoginDetails}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Background="{StaticResource WarningSubtle}"
                                                                                CornerRadius="6" Padding="10,6" Margin="0,0,0,4">
                                                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                                                <mi:MaterialIcon Grid.Column="0" Kind="AccountAlertOutline"
                                                                                                 Width="14" Height="14"
                                                                                                 Foreground="{StaticResource Warning}"
                                                                                                 Margin="0,0,8,0" VerticalAlignment="Top"/>
                                                                                <StackPanel Grid.Column="1" Spacing="2">
                                                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                                                        <TextBlock Text="{Binding IpAddress}" FontSize="12"
                                                                                                   FontFamily="Cascadia Code,Consolas,monospace"
                                                                                                   FontWeight="SemiBold"
                                                                                                   Foreground="{StaticResource TextPrimary}"/>
                                                                                        <TextBlock Text="{Binding AttemptsDisplay}" FontSize="11"
                                                                                                   Foreground="{StaticResource Warning}"/>
                                                                                    </StackPanel>
                                                                                    <TextBlock Text="{Binding PrimaryReasonFriendly}"
                                                                                               FontSize="11"
                                                                                               Foreground="{StaticResource TextSecondary}"/>
                                                                                    <TextBlock Text="{Binding UserNamesDisplay}" FontSize="10"
                                                                                               Foreground="{StaticResource TextMuted}"
                                                                                               TextTrimming="CharacterEllipsis"
                                                                                               IsVisible="{Binding UserNamesDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                                                </StackPanel>
                                                                                <TextBlock Grid.Column="2" Text="{Binding BrowserOrApp}"
                                                                                           FontSize="10"
                                                                                           Foreground="{StaticResource TextDisabled}"
                                                                                           VerticalAlignment="Top"/>
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>

                                                        <!-- Top API Endpoints -->
                                                        <StackPanel Spacing="6">
                                                            <TextBlock Text="Top API Endpoints" FontSize="13" FontWeight="SemiBold"
                                                                       Margin="0,4,0,0"/>
                                                            <ItemsControl ItemsSource="{Binding ShieldDashboard.TopApiEndpoints}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Background="{StaticResource BgTertiary}"
                                                                                CornerRadius="4" Padding="8,4" Margin="0,0,0,3">
                                                                            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                                                                <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                                                           FontSize="12"
                                                                                           Foreground="{StaticResource TextPrimary}"
                                                                                           TextTrimming="CharacterEllipsis"/>
                                                                                <TextBlock Grid.Column="1"
                                                                                           Text="{Binding CountDisplay}"
                                                                                           FontSize="11" Margin="8,0"
                                                                                           Foreground="{StaticResource TextMuted}"/>
                                                                                <TextBlock Grid.Column="2"
                                                                                           Text="{Binding AvgDurationDisplay}"
                                                                                           FontSize="11" Margin="8,0"
                                                                                           FontFamily="Cascadia Code,Consolas,monospace"
                                                                                           Foreground="{StaticResource Info}"/>
                                                                                <TextBlock Grid.Column="3"
                                                                                           Text="{Binding UniqueUsers, StringFormat={}{0} users}"
                                                                                           FontSize="10"
                                                                                           Foreground="{StaticResource TextDisabled}"/>
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>

                                                        <!-- Slowest Endpoints -->
                                                        <StackPanel Spacing="6">
                                                            <TextBlock Text="Slowest API Endpoints" FontSize="13" FontWeight="SemiBold"
                                                                       Margin="0,4,0,0"/>
                                                            <ItemsControl ItemsSource="{Binding ShieldDashboard.SlowestApiEndpoints}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Background="{StaticResource DangerSubtle}"
                                                                                CornerRadius="4" Padding="8,4" Margin="0,0,0,3">
                                                                            <Grid ColumnDefinitions="*,Auto,Auto">
                                                                                <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                                                           FontSize="12"
                                                                                           Foreground="{StaticResource TextPrimary}"
                                                                                           TextTrimming="CharacterEllipsis"/>
                                                                                <TextBlock Grid.Column="1"
                                                                                           Text="{Binding MaxDurationDisplay}"
                                                                                           FontSize="11" FontWeight="Bold"
                                                                                           FontFamily="Cascadia Code,Consolas,monospace"
                                                                                           Foreground="{StaticResource Danger}"
                                                                                           Margin="8,0"/>
                                                                                <TextBlock Grid.Column="2"
                                                                                           Text="{Binding CountDisplay}"
                                                                                           FontSize="10"
                                                                                           Foreground="{StaticResource TextMuted}"/>
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>

                                                        <!-- Apex Exceptions -->
                                                        <StackPanel Spacing="6">
                                                            <TextBlock Text="Apex Exceptions" FontSize="13" FontWeight="SemiBold"
                                                                       Margin="0,4,0,0"/>
                                                            <ItemsControl ItemsSource="{Binding ShieldDashboard.ApexExceptions}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Background="{StaticResource DangerSubtle}"
                                                                                CornerRadius="4" Padding="8,4" Margin="0,0,0,3">
                                                                            <Grid ColumnDefinitions="*,Auto">
                                                                                <StackPanel Grid.Column="0">
                                                                                    <TextBlock Text="{Binding Label}" FontSize="12"
                                                                                               FontWeight="SemiBold"
                                                                                               Foreground="{StaticResource TextPrimary}"
                                                                                               TextTrimming="CharacterEllipsis"/>
                                                                                    <TextBlock Text="{Binding SubLabel}" FontSize="10"
                                                                                               Foreground="{StaticResource TextMuted}"
                                                                                               TextTrimming="CharacterEllipsis"/>
                                                                                </StackPanel>
                                                                                <TextBlock Grid.Column="1"
                                                                                           Text="{Binding CountDisplay}"
                                                                                           FontSize="12" FontWeight="Bold"
                                                                                           Foreground="{StaticResource Danger}"
                                                                                           VerticalAlignment="Center"/>
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <!-- No dashboard state -->
                                                    <Border IsVisible="{Binding !ShieldDashboard, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                            Background="{StaticResource BgTertiary}"
                                                            CornerRadius="8" Padding="24,16">
                                                        <StackPanel HorizontalAlignment="Center" Spacing="8">
                                                            <mi:MaterialIcon Kind="ShieldOffOutline" Width="32" Height="32"
                                                                             Foreground="{StaticResource TextDisabled}"
                                                                             HorizontalAlignment="Center"/>
                                                            <TextBlock Text="No Shield data loaded"
                                                                       FontSize="13" Foreground="{StaticResource TextMuted}"
                                                                       HorizontalAlignment="Center"/>
                                                            <TextBlock Text="Connect to an org with Shield enabled to view security event monitoring"
                                                                       FontSize="11" Foreground="{StaticResource TextDisabled}"
                                                                       HorizontalAlignment="Center" TextWrapping="Wrap"
                                                                       TextAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Border>

                                            <!-- ═══ MONITORING ALERTS ═══ -->
                                            <Border Classes="card"
                                                    IsVisible="{Binding MonitoringAlerts.Count}">
                                                <StackPanel Spacing="8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <mi:MaterialIcon Kind="BellAlertOutline" Width="16" Height="16"
                                                                         Foreground="{StaticResource Warning}"/>
                                                        <TextBlock Text="Recent Alerts" FontSize="14" FontWeight="SemiBold"/>
                                                        <Border CornerRadius="10" Padding="6,1"
                                                                Background="{StaticResource Warning}"
                                                                IsVisible="{Binding UnreadAlertCount}">
                                                            <TextBlock Text="{Binding UnreadAlertCount}" FontSize="10"
                                                                       FontWeight="Bold" Foreground="#1C2128"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <ItemsControl ItemsSource="{Binding MonitoringAlerts}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border CornerRadius="6" Padding="10,6" Margin="0,0,0,4"
                                                                        Opacity="{Binding Opacity}"
                                                                        Background="{StaticResource BgTertiary}">
                                                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                                                        <Border Grid.Column="0" Width="4" CornerRadius="2"
                                                                                Margin="0,0,10,0" VerticalAlignment="Stretch">
                                                                            <Border.Background>
                                                                                <SolidColorBrush Color="{Binding SeverityColor}"/>
                                                                            </Border.Background>
                                                                        </Border>
                                                                        <StackPanel Grid.Column="1" Spacing="2">
                                                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="{StaticResource TextPrimary}"/>
                                                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                                                       Foreground="{StaticResource TextSecondary}"
                                                                                       TextTrimming="CharacterEllipsis" MaxLines="2"/>
                                                                            <TextBlock Text="{Binding ChangeDescription}" FontSize="10"
                                                                                       Foreground="{StaticResource TextMuted}"
                                                                                       IsVisible="{Binding ChangeDescription, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Column="2" VerticalAlignment="Top"
                                                                                    HorizontalAlignment="Right">
                                                                            <TextBlock Text="{Binding TimeAgo}" FontSize="10"
                                                                                       Foreground="{StaticResource TextDisabled}"/>
                                                                            <TextBlock Text="{Binding AffectedUsersDisplay}" FontSize="9"
                                                                                       Foreground="{StaticResource TextMuted}"
                                                                                       IsVisible="{Binding HasAffectedUsers}"/>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════ -->
        <!-- STATUS BAR (Row 2)                      -->
        <!-- ═══════════════════════════════════════ -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                Background="{StaticResource SidebarBg}"
                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Status Message -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center">
                    <mi:MaterialIcon Kind="InformationOutline" Width="12" Height="12"
                                     Foreground="{StaticResource TextMuted}"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                               Foreground="{StaticResource TextMuted}"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Right: License + Version -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <Border CornerRadius="3" Padding="6,1"
                            Background="{StaticResource BgHover}">
                        <TextBlock Text="{Binding TierDisplayName}" FontSize="10"
                                   FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                    </Border>
                    <TextBlock Text="Black Widow v1.0" FontSize="10"
                               Foreground="{StaticResource TextDisabled}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════ -->
        <!-- COMMAND PALETTE OVERLAY (Ctrl+K)        -->
        <!-- ═══════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="3" Grid.ColumnSpan="2"
                Background="#AA000000"
                IsVisible="{Binding IsCommandPaletteOpen}"
                PointerPressed="CommandPaletteBackdrop_PointerPressed"
                ZIndex="100">
            <Border Background="{StaticResource BgSecondary}"
                    CornerRadius="12" Width="620" MaxHeight="520"
                    VerticalAlignment="Top" Margin="0,80,0,0"
                    BorderBrush="{StaticResource BorderDefault}" BorderThickness="1">
                <Grid Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Search -->
                    <Grid Grid.Row="0" Margin="16,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <mi:MaterialIcon Kind="Magnify" Width="18" Height="18"
                                         Foreground="{StaticResource TextMuted}" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1" x:Name="CommandPaletteBox"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource TextPrimary}"
                                 Watermark="Type a command..."
                                 FontSize="15"
                                 TextChanged="CommandPaletteBox_TextChanged"
                                 KeyDown="CommandPaletteBox_KeyDown"/>
                    </Grid>

                    <!-- Results -->
                    <ListBox Grid.Row="1" x:Name="PaletteResultsList"
                             ItemsSource="{Binding PaletteResults}"
                             Background="Transparent" BorderThickness="0"
                             MaxHeight="380" Margin="8,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,8" CornerRadius="6">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{Binding Icon}" FontSize="16" VerticalAlignment="Center"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="13"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Help -->
                    <Border Grid.Row="2" BorderBrush="{StaticResource BorderSubtle}"
                            BorderThickness="0,1,0,0" Padding="16,8">
                        <TextBlock Text="↑↓ Navigate  ⏎ Execute  Esc Close"
                                   FontSize="11" Foreground="{StaticResource TextDisabled}"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
